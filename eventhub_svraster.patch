+
+def getLocalStereoPose(shift: float):
+    eye = np.eye(4)
+    eye[0, 3] = shift
+    return eye
+
+def mylinearposeinterpolator(pose_a: np.ndarray, pose_b: np.ndarray, n_frame: int):
+    """
+    Interpolates between two poses linearly.
+
+    :param pose_a: 4x4 numpy array
+        The first pose.
+    :param pose_b: 4x4 numpy array
+        The second pose.
+    :param n_frame: int
+        The number of frames to interpolate.
+    :return: list of 4x4 numpy arrays
+        The interpolated poses.
+    """
+    assert n_frame > 2, "Number of frames must be greater than 2"
+    
+    t = np.linspace(0, 1, n_frame).reshape(-1, 1) # N x 1
+    angle_vector_a = cv2.Rodrigues(pose_a[:3, :3])[0].T # 1 x 3
+    angle_vector_b = cv2.Rodrigues(pose_b[:3, :3])[0].T # 1 x 3
+    angle_vectors = (1-t) * angle_vector_a + t * angle_vector_b # N x 3
+    translations = (1-t) * pose_a[:3, 3] + t * pose_b[:3, 3] # N x 3
+
+    interp_poses = []
+    for i in range(n_frame):
+        interp_pose = np.eye(4)
+        interp_pose[:3, :3] = cv2.Rodrigues(angle_vectors[i])[0]
+        interp_pose[:3, 3] = translations[i]
+        interp_poses.append(interp_pose.astype(np.float32))
+        
+    return interp_poses
+
+def _mylinearposeinterpolator_wrapper(c2w: np.ndarray, camera_poses: list, n_frames_p: int, stereo_pose: np.ndarray, interpolate_start: bool = True, interpolate_end: bool = True):
+    stereo_corrected_c2w = np.linalg.inv(stereo_pose @ np.eye(4) @ np.linalg.inv(c2w)).astype(np.float32)
+
+    # If c2w is not the first pose
+    if np.linalg.norm(stereo_corrected_c2w - camera_poses[0]) > 0.1 and interpolate_start:
+        # Interpolate camera pose c2w -> camera_poses[0]
+        interp_poses_start = mylinearposeinterpolator(stereo_corrected_c2w, camera_poses[0], n_frames_p)
+    else:
+        interp_poses_start = []
+
+    # If c2w is not the last pose
+    if np.linalg.norm(stereo_corrected_c2w - camera_poses[-1]) > 0.1 and interpolate_end:
+        # Interpolate camera pose camera_poses[-1] -> c2w -- i.e., return to the original camera pose
+        interp_poses_end = mylinearposeinterpolator(camera_poses[-1], stereo_corrected_c2w, n_frames_p)
+    else:
+        interp_poses_end = []
+
+    # Concatenate poses
+    camera_poses = interp_poses_start + camera_poses + interp_poses_end
+
+    return camera_poses
+
+def nullLookAtEffect(c2w: np.ndarray, position: np.ndarray, stereo_shift: float, interpolate_start: bool = False, interpolate_end: bool = False, n_frames_p: int = 100, **kwargs):
+    stereo_pose = getLocalStereoPose(stereo_shift)
+    n_frames = position.shape[0]
+    T = position # N x 3
+    
+    camera_poses = []
+
+    for i in range(n_frames):
+        pose = np.eye(4)
+        pose[:3, 3] = T[i]
+        camera_poses.append(np.linalg.inv(stereo_pose @ pose @ np.linalg.inv(c2w)).astype(np.float32)) # 4 x 4
+        
+    camera_poses = _mylinearposeinterpolator_wrapper(c2w, camera_poses, n_frames_p, stereo_pose, interpolate_start=interpolate_start, interpolate_end=interpolate_end)
+    return camera_poses
+
+
+def manualLookAtEffect(c2w: np.ndarray, position: np.ndarray, stereo_shift: float, interpolate_start: bool = False, interpolate_end: bool = False, n_frames_p: int = 100, rot_axis_degree = None, **kwargs):
+    stereo_pose = getLocalStereoPose(stereo_shift)
+    n_frames = position.shape[0]
+    
+    if rot_axis_degree is None:
+        # Default rotation axis is [0, 0, 0] (no rotation)
+        # rot_axis_degree = np.array([0, 0, 0], dtype=np.float32)
+        return nullLookAtEffect(c2w=c2w, position=position, stereo_shift=stereo_shift, interpolate_start=interpolate_start, interpolate_end=interpolate_end, n_frames_p=n_frames_p)
+
+    # Assume manual_lookat is a 3D vector in degrees
+    if rot_axis_degree.ndim == 1:
+        assert rot_axis_degree.shape[0] == 3, f"rot_axis_degree must be a 3D vector, got {rot_axis_degree.shape}"
+        _axis_rot_degree = rot_axis_degree.reshape(1, 3).repeat(n_frames, axis=0) # N x 3
+    elif rot_axis_degree.ndim == 2 and rot_axis_degree.shape[0] != n_frames:
+        assert rot_axis_degree.shape[1] == 3, f"rot_axis_degree must be a 3D vector, got {rot_axis_degree.shape}"
+        _axis_rot_degree = rot_axis_degree[0].reshape(1, 3).repeat(n_frames, axis=0) # N x 3
+    else:
+        assert rot_axis_degree.shape[0] == n_frames and rot_axis_degree.shape[1] == 3, f"rot_axis_degree must be a 3D vector, got {rot_axis_degree.shape}"
+        _axis_rot_degree = rot_axis_degree  # N x 3
+
+    # Convert degrees to radians ASSUMES that the input is in degrees
+    _axis_rot_radian = np.deg2rad(_axis_rot_degree.astype(np.float32)) # 1 x 3
+
+    # Use kornia to support batch rotation matrices from axis-angle
+    _axis_rot_radian_tensor = torch.from_numpy(_axis_rot_radian).float()  # (N, 3)
+    R = kornia.geometry.axis_angle_to_rotation_matrix(_axis_rot_radian_tensor)[:, :3, :3].cpu().numpy()  # (N, 3, 3)
+    T = position # N x 3
+    
+    camera_poses = []
+
+    for i in range(n_frames):
+        pose = np.eye(4)
+        pose[:3, 3] = T[i] # before or after flip_eye? 
+        pose[:3, :3] = R[i]
+    
+        camera_poses.append(np.linalg.inv(stereo_pose @ pose @ np.linalg.inv(c2w)).astype(np.float32)) # 4 x 4
+
+    camera_poses = _mylinearposeinterpolator_wrapper(c2w, camera_poses, n_frames_p, stereo_pose, interpolate_start=interpolate_start, interpolate_end=interpolate_end)
+    return camera_poses
+
+def defaultLookAtEffect(c2w: np.ndarray, position: np.ndarray, stereo_shift: float, lookat_z: float = 10.0, interpolate_start: bool = False, interpolate_end: bool = False, n_frames_p: int = 100, **kwargs):
+    stereo_pose = getLocalStereoPose(stereo_shift)
+    # pose = np.eye(4) -- i.e., no roto-translation
+    
+    # position = np.array([x, y, z]) # 3 x N
+    # position = position.T # N x 3
+    n_frames = position.shape[0]
+    assert n_frames > 2, f"Number of frames must be greater than 2 ({position.shape})"
+
+    target = np.zeros((n_frames, 3), dtype=np.float32) # target point
+    target[:, 2] = lookat_z
+
+    # # Modified version to take in account for the very first pose
+    # target = ((c2w[:3, 3] - xyz_ref[:3, 3]) + np.array([0, 0, lookat_z])).reshape(1, 3).repeat(n_frames, axis=0) # N x 3
+    # # target = ((xyz_ref[:3, 3]-c2w[:3, 3]) + np.array([0, 0, lookat_z])).reshape(1, 3).repeat(n_frames, axis=0) # N x 3
+
+    # _z_cam_noise = np.random.normal(0, 0.0001, (n_frames, 3)).astype(np.float32) # small noise to avoid singularities
+    #normal noise is computationally expensive, so we use a uniform sampled noise
+    _z_cam_noise = np.random.uniform(-0.0001, 0.0001, (n_frames, 3)).astype(np.float32)
+
+    z_cam = (target-position) + _z_cam_noise # N x 3
+    z_cam /= np.linalg.norm(z_cam, axis=1, keepdims=True) # N x 3
+    
+    x_cam = np.cross(z_cam, np.array([0, 1, 0]).reshape(1,3).repeat(n_frames, axis=0)) # N x 3
+    x_cam /= np.linalg.norm(x_cam, axis=1, keepdims=True) # N x 3
+
+    y_cam = np.cross(z_cam, x_cam) # N x 3
+    y_cam /= np.linalg.norm(y_cam, axis=1, keepdims=True) # N x 3
+
+    R = np.stack([x_cam, y_cam, z_cam], axis=1) # N x 3 x 3
+    T = position # N x 3
+    
+    # Easy fix for inverted axis
+    flip_eye = np.eye(4)
+    flip_eye[0, 0] = -1
+    flip_eye[1, 1] = -1
+
+    camera_poses = []
+
+    for i in range(n_frames):
+        pose = np.eye(4)
+        pose[:3, 3] = T[i] # before or after flip_eye? 
+        pose[:3, :3] = R[i]
+        pose = flip_eye @ pose
+
+        camera_poses.append(np.linalg.inv(stereo_pose @ pose @ np.linalg.inv(c2w)).astype(np.float32)) # 4 x 4
+
+    camera_poses = _mylinearposeinterpolator_wrapper(c2w, camera_poses, n_frames_p, stereo_pose, interpolate_start=interpolate_start, interpolate_end=interpolate_end)
+    return camera_poses
+
+def cosineLookAtEffect(c2w: np.ndarray, position: np.ndarray, stereo_shift: float, freq_hz = None, rot_axis_degree_max = None, interpolate_start: bool = False, interpolate_end: bool = False, n_frames_p: int = 100, **kwargs):
+    # Assume phase equals 0
+    phase = 0.0
+    n_frames = position.shape[0]
+
+    #HINT: If freq_hz is not integer, final rotation will be different than the initial one
+
+    if freq_hz is None:
+        freq_hz = np.array([0.0, 0.0, 0.0], dtype=np.float32) # Default frequency (static)
+
+    if rot_axis_degree_max is None:
+        # Default rotation axis is [0, 0, 0] (no rotation)
+        rot_axis_degree_max = np.array([0.0, 0.0, 0.0], dtype=np.float32)
+
+    # Generate the trajectory
+    t = np.linspace(0, 1, n_frames)
+
+    x = rot_axis_degree_max[0] * np.cos(2 * np.pi * freq_hz[0] * t + phase)  # N
+    y = rot_axis_degree_max[1] * np.cos(2 * np.pi * freq_hz[1] * t + phase)  # N
+    z = rot_axis_degree_max[2] * np.cos(2 * np.pi * freq_hz[2] * t + phase)  # N
+
+    # create rot_axis_degree N x3
+    rot_axis_degree = np.concatenate([x.reshape(-1, 1), y.reshape(-1, 1), z.reshape(-1, 1)], axis=1) # N x 3
+
+    # Use the manualLookAtEffect to generate the camera poses
+    return manualLookAtEffect(c2w=c2w, position=position, stereo_shift=stereo_shift, rot_axis_degree=rot_axis_degree, interpolate_start=interpolate_start, interpolate_end=interpolate_end, n_frames_p=n_frames_p, **kwargs)
+
+
+LOOKAT_EFFECT_DICT = {
+    'null': nullLookAtEffect,
+    'manual': manualLookAtEffect,
+    'cosine': cosineLookAtEffect, # Cosine Rotation Effect
+    'default': defaultLookAtEffect, # Default look-at effect
+}
+
+def lookAtEffectWrapper(lookAt_fn, kwargs_a, kwargs_b):
+    # kwargs_a are priority arguments, kwargs_b are secondary arguments
+    # Join the two dictionaries, giving priority to kwargs_a:
+    # If a key exists in both, the value from kwargs_a will be used
+    kwargs = {**kwargs_b, **kwargs_a}
+    # Call the lookAt_fn with the combined arguments
+    return lookAt_fn(**kwargs)
