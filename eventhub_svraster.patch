+    # Project to image plane of camera b
+    pts_b_a_img = kornia.geometry.camera.perspective.project_points(pts_b_a, K) # 1 N 2 # type: ignore
+    pts_a_b_img = kornia.geometry.camera.perspective.project_points(pts_a_b, K) # 1 N 2 # type: ignore
+
