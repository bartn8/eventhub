+def trinocular_loss(disp, im1, im2, im3, uncertainty):
+    assert im1.shape == im2.shape == im3.shape, "Input images must have the same shape"
+    assert disp.dim() == 4 and disp.size(1) == 1, "Disparity must be a 4D tensor with a single channel"
+    assert im1.dim() == 4 and im1.size(1) == 3, "Input images must be 4D tensors with 3 channels"
+    assert uncertainty.dim() in [3, 4], "Uncertainty must be a 3D or 4D tensor"
+    uncertainty = uncertainty.squeeze(1) if uncertainty.dim() == 4 else uncertainty
+
+    im2_recons_from_1, mask_12 = disp_warp(im1, disp, r2l=True) # B 3 H W, B 1 H W
+    im2_recons_from_3, mask_23 = disp_warp(im3, disp, r2l=False) # B 3 H W, B 1 H W
+
+    photometric_loss_12 = photometric_loss(im2, mask_12 * im2_recons_from_1) # B 1 H W
+    photometric_loss_23 = photometric_loss(im2, mask_23 * im2_recons_from_3) # B 1 H W
+    loss_warp, _ = torch.min(torch.cat((photometric_loss_12, photometric_loss_23), dim=1), dim=1) # B H W
+
+    photometric_loss_1 = photometric_loss(im2, im1) # B 1 H W
+    photometric_loss_3 = photometric_loss(im2, im3) # B 1 H W 
+    loss_2, _ = torch.min(torch.cat((photometric_loss_1, photometric_loss_3), dim=1), dim=1) # B H W
+
+    automask = loss_warp < loss_2
+
+    loss = (loss_warp * uncertainty)
+    loss[~automask] = 0
+
+    return loss
+
+def binocular_loss(disp, im1, im2, uncertainty):
+    im1_recons, _ = disp_warp(im2, disp, r2l=False)
+
+    loss_warp = photometric_loss(im1, im1_recons)
+    loss_2 = photometric_loss(im2, im1)
+
+    automask = loss_warp < loss_2
+    loss = (loss_warp * uncertainty)
+    loss[~automask] = 0
+
+    return loss
+
+def image_loss(disp, im1, im2, im3, uncertainty, trinocular=True):
+    if trinocular:
+        return trinocular_loss(disp, im1, im2, im3, uncertainty)
+    else:
+        return binocular_loss(disp, im2, im3, uncertainty)
+
