+                            logger.log_clean_events_storage()
+                            break
+                    
+                    logger.log_events_flush_v2(_convert_ts(ts_pivot, args.duration)) # type: ignore
+                    
+                    # Render the sampled frame pose
+                    pose_next = pose_interpolator.interpolate(ts_pivot, shift=_stereo_shift, invert_t=invert_t)
+                    render_pkg_next = _render_fn(pose_next, voxel_model, fovx, fovy, width, height, output_depth=True, output_T=True)
+                                        
+                    # Process frame-based informations
+                    rendering_color_next = render_pkg_next['color'] # 3 H W                        
+                    rendering_depth_next = render_pkg_next['depth'][[0]] # 1 H W
+                    rendering_depth_median_next = render_pkg_next['depth'][[2]] # 1 H W
+                    
+                    rendering_ao_next = render_pkg_next['ao'] # 1 H W
+                    rendering_ao_next = rendering_ao_next / rendering_ao_next.max()
+
+                    rendering_sizeconf_next = render_pkg_next['sizeconf'] # 1 H W
+                    rendering_sizeconf_next = rendering_sizeconf_next / rendering_sizeconf_next.max()
+                    rendering_sizeconf_next = 1 - rendering_sizeconf_next # Invert the size confidence to match the AO
+
+                    rendering_alpha_next = render_pkg_next["T"]
+                    rendering_alpha_next = rendering_alpha_next / rendering_alpha_next.max()
+                    rendering_alpha_next = 1 - rendering_alpha_next # Invert the alpha to match the AO
+                    
+                    logger.log_timestamp(_convert_ts(ts_pivot, args.duration)) # type: ignore
+                    logger.log_pose(pose_next) 
+                    logger.log_color(rendering_color_next) 
+                    logger.log_depth(rendering_depth_next) 
+                    logger.log_depth_median(rendering_depth_median_next) 
+                    if mesh_depth_rendering:
+                        logger.log_depth_mesh(torch.from_numpy(render_depth_with_mesh_o3d(o3d_renderer, pose_next, width, height, focal_x, focal_y, c_x, c_y)).unsqueeze(0).float())
+                    logger.log_ao(rendering_ao_next) 
+                    logger.log_sizeconf(rendering_sizeconf_next) 
+                    logger.log_alpha(rendering_alpha_next) 
+
+                    # Update frame counter
+                    logger.step()
+
+    for _, logger in loggers.items():
+        logger.close()
+    
+    print(f"Finished rendering for model {args.model_path}.")
