+
+    # Controlla se tutte le posizioni sono dentro il bounding box
+    inside_bbox = np.all((all_positions >= bbox_min) & (all_positions <= bbox_max), axis=1)
+    all_inside = np.all(inside_bbox)
+    
+    if all_inside:
+        print(f"All poses are inside voxel model bounding box")
+        return 1.0, True
+    
+    # Se alcune pose sono fuori, calcola il fattore di scala
+    outside_positions = all_positions[~inside_bbox]
