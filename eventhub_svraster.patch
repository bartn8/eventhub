+import numpy as np
+from typing import Callable
+import cv2
+import torch
+import kornia
+import json
+
+def _xyz_z_proj_interpolate(xyz_ref: np.ndarray, n_frames_p: int):
+    """
+    Adds a linear interpolation between the last xyz_ref and its projection to the (0 0 z) axis.
+    """
+
+    # Get last item of xyz_ref
+    last_xyz = xyz_ref[-1].reshape(1, 3) # 1 x 3
+
+    # Project it to the (0 0 z) axis
+    projected_xyz = np.zeros_like(last_xyz) # 1 x 3
+    projected_xyz[0, 2] = last_xyz[0, 2] # keep the z value only
+
+    # Create a linear interpolation between the last xyz_ref and its projection
+    t = np.linspace(0, 1, n_frames_p).reshape(-1, 1) # N x 1
+
+    interpolated_xyz = (1 - t) * last_xyz + t * projected_xyz # N x 3
+
+    # Add the interpolated_xyz to the xyz_ref
+    xyz_ref = np.concatenate([xyz_ref, interpolated_xyz], axis=0) # (N + n_frames_p) x 3
+
+    return xyz_ref
+    
+
+def generateSpiralTrajectory(c2w: np.ndarray, xyz_ref: np.ndarray, lookat_fn: Callable, n_frames: int = 100, n_frames_p: int = 100, n_turns: float = 1, r_init: float = 0.0, init = None, offset = None, x_phase: float = 0.00, y_phase: float = 0.00, expansion_rate: float = 0.05, z_project: bool = False, rnd_phase: bool = True, rnd_theta_sign: bool = True, **kwargs):
+    a = r_init # initial radius -> assuming zero so the initial point is at the origin
+    b = expansion_rate # how fast it expands
+    theta = np.linspace(0, 2*n_turns*np.pi, n_frames)  
+
+    # Assume phase in degrees, convert to radians
+    x_phase = np.deg2rad(x_phase)
+    y_phase = np.deg2rad(y_phase)
+
+    # if random phases are enabled, generate random phases and override the input phases
+    if rnd_phase:
+        x_phase = np.random.uniform(0, 2*np.pi)
+        y_phase = 0
+
+    theta_sign = 1.0 if not rnd_theta_sign else np.random.choice([-1.0, 1.0])
+
+    if init is None:
+        init = np.array([0.0, 0.0, 0.0], dtype=np.float32) # Default initial position
+    if offset is None:
+        offset = np.array([0.0, 0.0, 0.0], dtype=np.float32) # Default offset
+
+    r = a + b * theta
+    x = -r * np.cos(theta_sign * theta + x_phase) # N
+    y = -r * np.sin(theta_sign * theta + y_phase) # N
+    z = np.zeros_like(x) # N
+
+    # add offsets
+    _len = len(x)
+    x += np.linspace(init[0], init[0]+offset[0], _len) # N
+    y += np.linspace(init[1], init[1]+offset[1], _len) # N
+    z += np.linspace(init[2], init[2]+offset[2], _len) # N
+
+    position = np.array([x, y, z]) # 3 x N
+    position = position.T # N x 3
+    position = position + xyz_ref if xyz_ref is not None else position # N x 3
+    position = _xyz_z_proj_interpolate(position, n_frames_p) if z_project else position # Project the last point to the (0 0 z) axis
+
+    return lookat_fn(c2w=c2w, position=position, interpolate_start=r_init > 0), position[-1].reshape(1, 3)
+
+def generateCircleTrajectory(c2w: np.ndarray, xyz_ref: np.ndarray, lookat_fn: Callable, n_frames: int = 100, n_frames_p: int = 100, n_turns: float = 1, r_init: float = 0.0, init = None, offset = None, x_phase: float = 0.00, y_phase: float = 0.00, z_project: bool = False, **kwargs):
+    return generateSpiralTrajectory(c2w=c2w, xyz_ref=xyz_ref, lookat_fn=lookat_fn, n_frames=n_frames, n_frames_p=n_frames_p, n_turns=n_turns, r_init=r_init, init=init, offset=offset, x_phase=x_phase, y_phase=y_phase, expansion_rate=0, z_project=z_project, **kwargs)
+
+def generateCrossTrajectory(c2w: np.ndarray, xyz_ref: np.ndarray, lookat_fn: Callable, n_frames: int = 100, n_frames_p: int = 100, max_radius: float = 0.5, init = None, offset = None, z_project: bool = False, **kwargs):
+    phase = 0.0
+
+    # split n_frames into eight parts
+    n_frames = n_frames + (n_frames % 8) # make sure n_frames is divisible by 8
+
+    # Generate the trajectory
+    x_list = []
+    y_list = []
+
+    start_list = [0, 1, 0, -1]
+    end_list = [1, 0, -1, 0]
+
+    for i in range(8):
+        additional_phase = np.pi / 2 if i > 3 else 0
+        radius = np.linspace(start_list[i%4], end_list[i%4], n_frames//8) # N/8 x 1
+
+        radius = max_radius * radius # N/8 x 1
+        x = radius * np.cos(phase + additional_phase) # N/8 x 1
+        y = radius * np.sin(phase + additional_phase) # N/8 x 1
+        x_list.append(x)
+        y_list.append(y)
+
+    if init is None:
+        init = np.array([0.0, 0.0, 0.0], dtype=np.float32) # Default initial position
+    if offset is None:
+        offset = np.array([0.0, 0.0, 0.0], dtype=np.float32) # Default offset
+
+    x = np.concatenate(x_list, axis=0) # N
+    y = np.concatenate(y_list, axis=0) # N
+    z = np.zeros_like(x) # N
+
+    # add offsets
+    _len = len(x)
+    x += np.linspace(init[0], init[0]+offset[0], _len) # N
+    y += np.linspace(init[1], init[1]+offset[1], _len) # N
+    z += np.linspace(init[2], init[2]+offset[2], _len) # N
+
+    position = np.array([x, y, z]) # 3 x N
+    position = position.T # N x 3
+    position = position + xyz_ref if xyz_ref is not None else position # N x 3
+    position = _xyz_z_proj_interpolate(position, n_frames_p) if z_project else position # Project the last point to the (0 0 z) axis
+
+    return lookat_fn(c2w=c2w, position=position), position[-1].reshape(1, 3)
+
+def generateLinearTrajectory(c2w: np.ndarray, xyz_ref: np.ndarray, lookat_fn: Callable, n_frames: int = 100, n_frames_p: int = 100, max_radius: float = 0.5, init = None, offset = None, phase: float = 0.0, z_project: bool = False, **kwargs):
+    # Assume phase in degrees, convert to radians
+    phase = np.deg2rad(phase)
+
+    # split n_frames into eight parts
+    n_frames = n_frames + (n_frames % 4) # make sure n_frames is divisible by 4
+
+    # Generate the trajectory
+    x_list = []
+    y_list = []
+
+    start_list = [0, 1, 0, -1]
+    end_list = [1, 0, -1, 0]
+
+    for i in range(4):
+        radius = np.linspace(start_list[i], end_list[i], n_frames//4) # N/4 x 1
+
+        radius = max_radius * radius # N/4 x 1
+        x = radius * np.cos(phase) # N/4 x 1
+        y = radius * np.sin(phase) # N/4 x 1
+        x_list.append(x)
+        y_list.append(y)
+
+    if init is None:
+        init = np.array([0.0, 0.0, 0.0], dtype=np.float32) # Default initial position
+    if offset is None:
+        offset = np.array([0.0, 0.0, 0.0], dtype=np.float32) # Default offset
+
+    x = np.concatenate(x_list, axis=0) # N
+    y = np.concatenate(y_list, axis=0) # N
+    z = np.zeros_like(x) # N
+
+    # add offsets
+    _len = len(x)
+    x += np.linspace(init[0], init[0]+offset[0], _len) # N
+    y += np.linspace(init[1], init[1]+offset[1], _len) # N
+    z += np.linspace(init[2], init[2]+offset[2], _len) # N
+
+    position = np.array([x, y, z]) # 3 x N
+    position = position.T # N x 3
+    position = position + xyz_ref if xyz_ref is not None else position # N x 3
+    position = _xyz_z_proj_interpolate(position, n_frames_p) if z_project else position # Project the last point to the (0 0 z) axis
+
+    return lookat_fn(c2w=c2w, position=position), position[-1].reshape(1, 3)
+
+def generateCosineTrajectory(c2w: np.ndarray, xyz_ref: np.ndarray, lookat_fn: Callable, n_frames: int = 100, n_frames_p: int = 100, max_radius: float = 0.5, freq_hz = None, init = None, offset = None, phase: float = 0.0, z_project: bool = False, **kwargs):
+    # Assume phase equals 0
+    phase = 0.0
+
+    if freq_hz is None:
+        freq_hz = np.array([0.0, 0.0, 0.0], dtype=np.float32) # Default frequency (static)
+
+    # Generate the trajectory
+    t = np.linspace(0, 1, n_frames)
+
+    x = max_radius * np.cos(2 * np.pi * freq_hz[0] * t + phase)  # N
+    y = max_radius * np.cos(2 * np.pi * freq_hz[1] * t + phase)  # N
+    z = max_radius * np.cos(2 * np.pi * freq_hz[2] * t + phase)  # N
+
+    if init is None:
+        init = np.array([0.0, 0.0, 0.0], dtype=np.float32) # Default initial position
+    if offset is None:
+        offset = np.array([0.0, 0.0, 0.0], dtype=np.float32) # Default offset
+
+    # add offsets
+    _len = len(x)
+    x += np.linspace(init[0], init[0]+offset[0], _len) # N
+    y += np.linspace(init[1], init[1]+offset[1], _len) # N
+    z += np.linspace(init[2], init[2]+offset[2], _len) # N
+
+    position = np.array([x, y, z]) # 3 x N
+    position = position.T # N x 3
+    position = position + xyz_ref if xyz_ref is not None else position # N x 3
+    position = _xyz_z_proj_interpolate(position, n_frames_p) if z_project else position # Project the last point to the (0 0 z) axis
+
+    return lookat_fn(c2w=c2w, position=position), position[-1].reshape(1, 3)
+
+def generateRepeatedRandomLinearTrajectory(c2w: np.ndarray, xyz_ref: np.ndarray, lookat_fn: Callable, n_frames: int = 100, n_frames_p: int = 100, n_iters = 1, max_radius: float = 0.5, init = None, offset = None, z_project: bool = False, **kwargs):
+    """ Generates a linear trajectory that repeats n_iters times. """
+
+    n_frames_iter = n_frames // n_iters
+
+    init = np.array([0.0, 0.0, 0.0], dtype=np.float32) if init is None else init
+    offset = np.array([0.0, 0.0, 0.0], dtype=np.float32) if offset is None else offset
+
+    offset_iter = (offset) / n_iters if n_iters > 1 else offset
+
+    poses_list = []
+    for i in range(n_iters):
+        rnd_phase = np.random.uniform(0, 360)
+        # Generate a linear trajectory for each iteration
+        poses, xyz_ref = generateLinearTrajectory(
+            c2w=c2w,
+            xyz_ref=xyz_ref,
+            lookat_fn=lookat_fn,
+            n_frames=n_frames_iter,
+            n_frames_p=n_frames_p,
+            max_radius=max_radius,
+            init=init if i == 0 else np.array([0.0, 0.0, 0.0], dtype=np.float32), # init is only used for the first iteration
+            offset=offset_iter,
+            phase=rnd_phase,
+            z_project=z_project,
+            **kwargs
+        )
+        poses_list += poses
+
+    return poses_list, xyz_ref
+
