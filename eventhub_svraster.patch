+        pose_a_b = kornia.geometry.linalg.compose_transformations(pose_a, kornia.geometry.linalg.inverse_transformation(pose_b)) # 1 4 4 # type: ignore
+
+    # Transform points to relative coordinates
+    pts_b_a = kornia.geometry.linalg.transform_points(pose_b_a, pts_a) # 1 N 3 # type: ignore
+    pts_a_b = kornia.geometry.linalg.transform_points(pose_a_b, pts_b) # 1 N 3 # type: ignore
