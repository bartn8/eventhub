+import numpy as np
+import cv2
+from typing import Callable, Optional
+
+def getLocalStereoPose(shift: float):
+    eye = np.eye(4)
+    eye[0, 3] = shift
+    return eye
+
+def getPose(c2w: np.ndarray, position: np.ndarray, rot_axis_degree: np.ndarray, shift: float = 0.0):
+    assert position.ndim == 1 and position.shape[0] == 3, f"position must be a 3D vector, got {position.shape}"
+    assert rot_axis_degree.ndim == 1 and rot_axis_degree.shape[0] == 3, f"rot_axis_degree must be a 3D vector, got {rot_axis_degree.shape}"
+
+    stereo_pose = getLocalStereoPose(shift)
+    pose = np.eye(4)
+    pose[:3, 3] = position
+    pose[:3, :3] = cv2.Rodrigues(np.deg2rad(rot_axis_degree))[0]  # Convert degrees to radians and get rotation matrix
+    return np.linalg.inv(stereo_pose @ pose @ np.linalg.inv(c2w)).astype(np.float32)
+
+def manualParamTrajectory(t: float, amplitude: np.ndarray):
+    amplitude = np.array(amplitude, dtype=np.float64)
+
+    assert 0 <= t <= 1, "t must be inside range [0, 1]"
+    assert amplitude.ndim == 1 and amplitude.shape[0] == 3, f"amplitude must be a 3D vector, got {amplitude.shape}"
+    return np.array(amplitude, dtype=np.float64)
+
+def cosineParamTrajectory(t: float, freq_hz: np.ndarray = np.array([1.0, 1.0, 1.0]), amplitude: np.ndarray = np.array([0.1, 0.1, 0.1]), invert: bool = False):
+    freq_hz = np.array(freq_hz, dtype=np.float64)
+    amplitude = np.array(amplitude, dtype=np.float64)
+
+    assert 0 <= t <= 1, "t must be inside range [0, 1]"
+    assert freq_hz.ndim == 1 and freq_hz.shape[0] == 3, f"freq_hz must be a 3D vector, got {freq_hz.shape}"
+    assert amplitude.ndim == 1 and amplitude.shape[0] == 3, f"amplitude must be a 3D vector, got {amplitude.shape}"
+
+    if invert:
+        t = 1 - t
+
+    x = amplitude[0] * np.cos(2 * np.pi * freq_hz[0] * t)  # 1
+    y = amplitude[1] * np.cos(2 * np.pi * freq_hz[1] * t)  # 1
+    z = amplitude[2] * np.cos(2 * np.pi * freq_hz[2] * t)  # 1
+
+    return np.array([x, y, z], dtype=np.float64)
+
+def sineParamTrajectory(t: float, freq_hz: np.ndarray = np.array([1.0, 1.0, 1.0]), amplitude: np.ndarray = np.array([0.1, 0.1, 0.1]), invert: bool = False):
+    freq_hz = np.array(freq_hz, dtype=np.float64)
+    amplitude = np.array(amplitude, dtype=np.float64)
+
+    assert 0 <= t <= 1, "t must be inside range [0, 1]"
+    assert freq_hz.ndim == 1 and freq_hz.shape[0] == 3, f"freq_hz must be a 3D vector, got {freq_hz.shape}"
+    assert amplitude.ndim == 1 and amplitude.shape[0] == 3, f"amplitude must be a 3D vector, got {amplitude.shape}"
+
+    if invert:
+        t = 1 - t
+
+    x = amplitude[0] * np.sin(2 * np.pi * freq_hz[0] * t)  # 1
+    y = amplitude[1] * np.sin(2 * np.pi * freq_hz[1] * t)  # 1
+    z = amplitude[2] * np.sin(2 * np.pi * freq_hz[2] * t)  # 1
+
+    return np.array([x, y, z], dtype=np.float64)
+
+def triangleParamTrajectory(t: float, freq_hz: np.ndarray = np.array([1.0, 1.0, 1.0]), amplitude: np.ndarray = np.array([0.1, 0.1, 0.1]), invert: bool = False):
+    amplitude = np.array(amplitude, dtype=np.float64)
+    freq_hz = np.array(freq_hz, dtype=np.float64)
+
+    assert 0 <= t <= 1, "t must be inside range [0, 1]"
+    assert freq_hz.ndim == 1 and freq_hz.shape[0] == 3, f"freq_hz must be a 3D vector, got {freq_hz.shape}"
+    assert amplitude.ndim == 1 and amplitude.shape[0] == 3, f"amplitude must be a 3D vector, got {amplitude.shape}"
+
+    if invert:
+        t = 1 - t
+
+    abs_freq_hz = np.abs(freq_hz)  # Ensure frequencies are positive
+    
+    # Formula: y(t) = (4 * f * amplitude) * abs(((t - 1 / (4 * freq_hz)) % (1 / freq_hz)) - 1 / (2 * freq_hz)) - amplitude
+    x = (4 * abs_freq_hz[0] * amplitude[0]) * np.abs(np.mod(t - (1 / (4 * abs_freq_hz[0])), 1 / abs_freq_hz[0]) - (1 / (2 * abs_freq_hz[0]))) - amplitude[0] if freq_hz[0] != 0 else 0
+    y = (4 * abs_freq_hz[1] * amplitude[1]) * np.abs(np.mod(t - (1 / (4 * abs_freq_hz[1])), 1 / abs_freq_hz[1]) - (1 / (2 * abs_freq_hz[1]))) - amplitude[1] if freq_hz[1] != 0 else 0
+    z = (4 * abs_freq_hz[2] * amplitude[2]) * np.abs(np.mod(t - (1 / (4 * abs_freq_hz[2])), 1 / abs_freq_hz[2]) - (1 / (2 * abs_freq_hz[2]))) - amplitude[2] if freq_hz[2] != 0 else 0
+
+    return np.array([x, y, z], dtype=np.float64)
+
+def spiralParamTrajectory(t: float, freq_hz: float = 1.0, amplitude: np.ndarray = np.array([0.1, 0.1]), invert: bool = False):
+    amplitude = np.array(amplitude, dtype=np.float64)
+
+    assert 0 <= t <= 1, "t must be inside range [0, 1]"
+    assert amplitude.ndim == 1 and amplitude.shape[0] == 2, f"amplitude must be a 2D vector, got {amplitude.shape}"
+
+    if invert:
+        t = 1 - t
+
+    x = (amplitude[0] * t) * np.cos(2 * np.pi * freq_hz * t) 
+    y = (amplitude[1] * t) * np.sin(2 * np.pi * freq_hz * t)
+    z = 0
+
+    return np.array([x, y, z], dtype=np.float64)
+
+def circleParamTrajectory(t: float, freq_hz: float = 1.0, amplitude: np.ndarray = np.array([0.1, 0.1])):
+    amplitude = np.array(amplitude, dtype=np.float64)
+
+    assert 0 <= t <= 1, "t must be inside range [0, 1]"
+    assert amplitude.ndim == 1 and amplitude.shape[0] == 2, f"amplitude must be a 2D vector, got {amplitude.shape}"
+
+    x = amplitude[0] * np.cos(2 * np.pi * freq_hz * t)
+    y = amplitude[1] * np.sin(2 * np.pi * freq_hz * t)
+    z = 0
+    
+    return np.array([x, y, z], dtype=np.float64)
+
+def linearParamTrajectory(t: float, start: np.ndarray, end: np.ndarray):
+    start = np.array(start, dtype=np.float64)
+    end = np.array(end, dtype=np.float64)
+
+    assert 0 <= t <= 1, "t must be inside range [0, 1]"
+    assert start.ndim == 1 and start.shape[0] == 3, f"start must be a 3D vector, got {start.shape}"
+    assert end.ndim == 1 and end.shape[0] == 3, f"end must be a 3D vector, got {end.shape}"
+
+    return (1 - t) * start + t * end
+
+TRAJ_DICT = {
+    'manual': manualParamTrajectory,
+    'cosine': cosineParamTrajectory,
+    'triangle': triangleParamTrajectory,
+    'spiral': spiralParamTrajectory,
+    'circle': circleParamTrajectory,
+    'linear': linearParamTrajectory,
+    'sine': sineParamTrajectory
+}
+
+class RootNode:
+    def __init__(self, pos_trajectory_fn: Callable, rot_degree_trajectory_fn: Callable):
+        self.pos_trajectory_fn = pos_trajectory_fn
+        self.rot_degree_trajectory_fn = rot_degree_trajectory_fn
+
+    def __call__(self, c2w: np.ndarray, t: float, shift: float = 0.0) -> np.ndarray:
+        assert 0 <= t <= 1, "t must be in the range [0, 1]"
+        return getPose(c2w, position=self.pos_trajectory_fn(t), rot_axis_degree=self.rot_degree_trajectory_fn(t), shift=shift)
+
+class ConcatNode:
+    def __init__(self, children_fns: list):
+        self.children_fns = children_fns
+        self.children_t_ranges = [(i+1) / len(children_fns) for i in range(len(children_fns))]
+        self.children_len = len(children_fns)
+
+    def __call__(self, t: float) -> np.ndarray:
+        assert 0 <= t <= 1, "t must be in the range [0, 1]"
+        old_t_th = 0
+        for i, t_th in enumerate(self.children_t_ranges):
+            if t <= t_th:
+                # Scale time
+                return self.children_fns[i]((t - old_t_th) * self.children_len)
+            old_t_th = t_th
+        raise ValueError(f"Time {t} is out of range for concatenated nodes. Expected [0, 1], got {t}.")
+
+class MeanNode:
+    def __init__(self, children_fns: list):
+        self.children_fns = children_fns
+        self.children_len = len(children_fns)
+
+    def __call__(self, t: float) -> np.ndarray:
+        assert 0 <= t <= 1, "t must be in the range [0, 1]"
+        xyzs = []
+        for fn in self.children_fns:
+            xyz = fn(t)
+            xyzs.append(xyz)
+        
+        # Average xyz
+        return np.mean(xyzs, axis=0)
+
+class LeafNode:
+    def __init__(self, trajectory_fn: Callable):
+        self.trajectory_fn = trajectory_fn
+
+    def __call__(self, t: float) -> np.ndarray:
+        assert 0 <= t <= 1, "t must be in the range [0, 1]"
+        xyz = self.trajectory_fn(t)
+        return xyz
+
+class SumNode:
+    def __init__(self, children_fns: list):
+        self.children_fns = children_fns
+        self.children_len = len(children_fns)
+
+    def __call__(self, t: float) -> np.ndarray:
+        assert 0 <= t <= 1, "t must be in the range [0, 1]"
+        xyzs = []
+        for fn in self.children_fns:
+            xyz = fn(t)
+            xyzs.append(xyz)
+        
+        # Sum xyz
+        return np.sum(xyzs, axis=0)
+
+NODE_DICT = {
+    'root': RootNode,
+    'concat': ConcatNode,
+    'mean': MeanNode,
+    'leaf': LeafNode,
+    'sum': SumNode
+}
+
+
+def parseTrajectoryConfig(config_node: dict) -> Callable:
+    node_type = config_node.get('type', 'none')
+    if node_type not in NODE_DICT:
+        raise ValueError(f"Unknown node type: {node_type}. Available types: {list(NODE_DICT.keys())}")
+    
+    if node_type == 'root':
+        # Root node should have two 'children' key with each one encoding respectively the position and rotation degree trajectories
+        pos_child_config = config_node.get('pos_trajectory_child', {})
+        rot_child_config = config_node.get('rot_degree_trajectory_child', {})
+        if not isinstance(pos_child_config, dict):
+            raise ValueError("Root node must have a 'pos_trajectory_child' key with a configuration dictionary.")
+        if not isinstance(rot_child_config, dict):
+            raise ValueError("Root node must have a 'rot_degree_trajectory_child' key with a configuration dictionary.")
+
+        pos_child_fn = parseTrajectoryConfig(pos_child_config)
+        rot_child_fn = parseTrajectoryConfig(rot_child_config)
+        return NODE_DICT[node_type](pos_child_fn, rot_child_fn)
+
+    elif node_type == 'leaf':
+        # Leaf node should have a 'trajectory' key with the trajectory type
+        trajectory_type = config_node.get('trajectory_type', 'none')
+        trajectory_args = config_node.get('trajectory_args', {})
+        
+        if trajectory_type not in TRAJ_DICT:
+            raise ValueError(f"Unknown trajectory type: {trajectory_type}. Available types: {list(TRAJ_DICT.keys())}")
+        
+        trajectory_fn = lambda t: TRAJ_DICT[trajectory_type](t, **trajectory_args)
+        
+        return NODE_DICT[node_type](trajectory_fn)
+    
+    elif node_type in ['concat', 'mean', 'sum']:
+        # Concat node should have 'children' key with a list of child configurations
+        children = config_node.get('children', [])
+        if not isinstance(children, list) or len(children) == 0:
+            raise ValueError("Concat node must have a non-empty 'children' list.")
+
+        children_fns = [parseTrajectoryConfig(child) for child in children]
+        return NODE_DICT[node_type](children_fns)
+    
+    raise ValueError(f"Unknown node type: {node_type}. Available types: {list(NODE_DICT.keys())}")
+        
+if __name__ == "__main__":
+    # Example usage
+    import json
+    import open3d as o3d
+    import matplotlib.cm as cm
