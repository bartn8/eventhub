+    if c2w:
+        # If camera 2 world
+        pose_b_a = kornia.geometry.linalg.compose_transformations(kornia.geometry.linalg.inverse_transformation(pose_b), pose_a) # 1 4 4 # type: ignore
+        pose_a_b = kornia.geometry.linalg.compose_transformations(kornia.geometry.linalg.inverse_transformation(pose_a), pose_b) # 1 4 4 # type: ignore
+    else: 
+        # If world 2 camera
+        pose_b_a = kornia.geometry.linalg.compose_transformations(pose_b, kornia.geometry.linalg.inverse_transformation(pose_a)) # 1 4 4 # type: ignore
+        pose_a_b = kornia.geometry.linalg.compose_transformations(pose_a, kornia.geometry.linalg.inverse_transformation(pose_b)) # 1 4 4 # type: ignore
+
+    # Transform points to relative coordinates
+    pts_b_a = kornia.geometry.linalg.transform_points(pose_b_a, pts_a) # 1 N 3 # type: ignore
+    pts_a_b = kornia.geometry.linalg.transform_points(pose_a_b, pts_b) # 1 N 3 # type: ignore
+
+    # Project to image plane
+    pts_b_a_img = kornia.geometry.camera.perspective.project_points(pts_b_a, K) # 1 N 2 # type: ignore
+    pts_a_b_img = kornia.geometry.camera.perspective.project_points(pts_a_b, K) # 1 N 2 # type: ignore
+
+    # Optical flow vectors
+    F_0_1 = pts_a_b_img[..., :2] - coords[..., :2]
+    F_1_0 = pts_b_a_img[..., :2] - coords[..., :2]
+    
+    # Mask invalid optical flow values
+    valid_mask_0_1 = (
+        (pts_a_b_img[..., 0] > 0) &
+        (pts_a_b_img[..., 0] < W) &
+        (pts_a_b_img[..., 1] > 0) &
+        (pts_a_b_img[..., 1] < H) &
+        (pts_a_b[..., 2] > 0) &
+        (~torch.isnan(pts_a_b_img[..., 0])) &
+        (~torch.isnan(pts_a_b_img[..., 1])) &
+        (~torch.isinf(pts_a_b_img[..., 0])) &
+        (~torch.isinf(pts_a_b_img[..., 1]))
+    )
+
+    valid_mask_1_0 = (
+        (pts_b_a_img[..., 0] > 0) &
+        (pts_b_a_img[..., 0] < W) &
+        (pts_b_a_img[..., 1] > 0) &
+        (pts_b_a_img[..., 1] < H) &
+        (pts_b_a[..., 2] > 0) &
+        (~torch.isnan(pts_b_a_img[..., 0])) &
+        (~torch.isnan(pts_b_a_img[..., 1])) &
+        (~torch.isinf(pts_b_a_img[..., 0])) &
+        (~torch.isinf(pts_b_a_img[..., 1]))
+    )
+    
+    _F_0_1 = F_0_1[valid_mask_0_1]
+    _F_1_0 = F_1_0[valid_mask_1_0]
+    
+    # If no valid flow values, return empty arrays
+    if _F_0_1.numel() == 0 or _F_1_0.numel() == 0:
+        print("Warning: No valid optical flow values found.")
+        return np.array([]), np.array([]), np.zeros((H, W)), np.zeros((H, W))
+
+    # Apply quantile-based filtering to remove spurious flow vectors
+    flow_mag_0_1 = (_F_0_1 ** 2).sum(-1) ** 0.5
+    flow_mag_1_0 = (_F_1_0 ** 2).sum(-1) ** 0.5
+    
+    quantile_0_1 = torch.quantile(flow_mag_0_1, quantile)
+    quantile_1_0 = torch.quantile(flow_mag_1_0, quantile)
+    
+    filter_mask_0_1 = flow_mag_0_1 <= quantile_0_1
+    filter_mask_1_0 = flow_mag_1_0 <= quantile_1_0
+    
+    # Create combined masks and reconstruct full arrays
+    # Initialize full flow arrays
+    F_0_1_full = torch.zeros_like(F_0_1)
+    F_1_0_full = torch.zeros_like(F_1_0)
+    
+    # Place filtered values back into full arrays at valid positions
+    F_0_1_full[valid_mask_0_1] = _F_0_1
+    F_1_0_full[valid_mask_1_0] = _F_1_0
+    
+    # Zero out values that don't pass quantile filter
+    valid_indices_0_1 = torch.where(valid_mask_0_1)
+    valid_indices_1_0 = torch.where(valid_mask_1_0)
+    
+    # Create inverse mapping from valid indices to filter mask
+    temp_0_1 = torch.zeros_like(valid_mask_0_1)
+    temp_1_0 = torch.zeros_like(valid_mask_1_0)
+    temp_0_1[valid_indices_0_1] = filter_mask_0_1
+    temp_1_0[valid_indices_1_0] = filter_mask_1_0
+    
+    F_0_1_full[~temp_0_1.bool()] = 0
+    F_1_0_full[~temp_1_0.bool()] = 0
+    
+    F_0_1_filtered = F_0_1_full.numpy().reshape(H, W, 2)
+    F_1_0_filtered = F_1_0_full.numpy().reshape(H, W, 2)
+
+    valid_mask_0_1 = valid_mask_0_1.numpy().reshape(H, W)
+    valid_mask_1_0 = valid_mask_1_0.numpy().reshape(H, W)
+
+    return F_0_1_filtered, F_1_0_filtered, valid_mask_0_1, valid_mask_1_0
+
+def left_center_right_check(left_disp: torch.Tensor, center_disp: torch.Tensor, right_disp: torch.Tensor, threshold: float = 1.0) -> torch.Tensor:
+    """
+    Perform left-center-right consistency check on disparity maps.
+
+    Args:
+        left_disp (np.ndarray): Disparity map from the left view.
+        center_disp (np.ndarray): Disparity map from the center view.
+        right_disp (np.ndarray): Disparity map from the right view.
+        threshold (float): Threshold for consistency check.
+
+    Returns:
+        np.ndarray: Validity mask indicating consistent pixels.
+    """
+    assert left_disp.shape == center_disp.shape == right_disp.shape, "All disparity maps must have the same shape."
+    assert left_disp.ndim == 4 or left_disp.ndim == 3, "Disparity maps must be 3D or 4D tensors (B, C, H, W)."
+    
+    if left_disp.ndim == 3:
+        left_disp = left_disp.unsqueeze(0)
+        center_disp = center_disp.unsqueeze(0)
+        right_disp = right_disp.unsqueeze(0)
+    
+    B, C, H, W = center_disp.shape
+    
+    # Disparities should be positive
+    left_disp = torch.abs(left_disp)
+    center_disp = torch.abs(center_disp)
+    right_disp = torch.abs(right_disp)
+    
+    coords = kornia.utils.create_meshgrid(H, W, normalized_coordinates=False).to(center_disp.device)  # 1 H W 2
+    coords = coords.repeat(B, 1, 1, 1)  # B H W 2
+    
+    # Project left to center
+    left_to_center_coords = coords.clone()
+    left_to_center_coords[..., 0] = left_to_center_coords[..., 0] + center_disp.squeeze(1)
+    left_to_center_coords_norm = torch.stack([
+        2.0 * left_to_center_coords[..., 0] / (W - 1) - 1.0,
+        2.0 * left_to_center_coords[..., 1] / (H - 1) - 1.0
+    ], dim=-1)  # B H W 2
+    
+    left_disp_warped = F.grid_sample(left_disp, left_to_center_coords_norm, mode='bilinear', padding_mode='zeros', align_corners=True)  # B 1 H W
+    
+    # Project right to center
+    right_to_center_coords = coords.clone()
+    right_to_center_coords[..., 0] = right_to_center_coords[..., 0] - center_disp.squeeze(1)
+    right_to_center_coords_norm = torch.stack([
+        2.0 * right_to_center_coords[..., 0] / (W - 1) - 1.0,
+        2.0 * right_to_center_coords[..., 1] / (H - 1) - 1.0
+    ], dim=-1)  # B H W 2
+    
+    right_disp_warped = F.grid_sample(right_disp, right_to_center_coords_norm, mode='bilinear', padding_mode='zeros', align_corners=True)  # B 1 H W
+    
+    # Consistency check
+    left_consistency = torch.abs(left_disp_warped - center_disp) 
+    right_consistency = torch.abs(right_disp_warped - center_disp)
+    min_consistency = torch.min(left_consistency, right_consistency)
+    
+    return (min_consistency < threshold)  # B 1 H W
+
+def optimize_disp(disp, im1, im2, im3, uncertainty=None, lr=1e-3, iters=10):
+    assert (disp.dim() == 4 and disp.size(1) == 1) or (disp.dim() == 3 and disp.size(0) == 1), "Disparity must be a 3D or 4D tensor with a single channel"
+    assert im1.shape == im2.shape == im3.shape, "Input images must have the same shape"
+    assert (im1.dim() == 4 and im1.size(1) == 3) or (im1.dim() == 3 and im1.size(0) == 3), "Input images must be a 3D or 4D tensors with 3 channels"
+    assert uncertainty is None or (uncertainty.dim() in [3, 4]), "Uncertainty must be a 3D or 4D tensor"
+    
+    if disp.dim() == 3:
+        disp = disp.unsqueeze(0)
+        
+    if im1.dim() == 3:
+        im1 = im1.unsqueeze(0)
+        im2 = im2.unsqueeze(0)
+        im3 = im3.unsqueeze(0)
+    
+    if uncertainty is None:
+        uncertainty = torch.ones_like(disp)
+    
+    # parametri da ottimizzare
+    a = torch.nn.Parameter(torch.tensor(1.00, device=disp.device))
+    b = torch.nn.Parameter(torch.tensor(0.00, device=disp.device))
+
+    optimizer = optim.SGD([a, b], lr=lr)
+
+    for i in range(iters):
+        optimizer.zero_grad()
+
+        # fit lineare
+        disp_fit = a * disp + b
+
+        # calcolo loss
+        loss = trinocular_loss(disp_fit, im1, im2, im3, uncertainty).mean()
+
+        # backward + step
+        loss.backward()
+        optimizer.step()
+
+        #print(f"Iter {i}: loss={loss.item():.6f}, a={a.item():.6f}, b={b.item():.6f}")
+
+    return float(a.item()), float(b.item())
+
+if __name__ == "__main__":
+    import matplotlib.pyplot as plt
+    import flow_vis
+
+    # Example usage
+    depth_a = np.full((480, 640), 100.0, dtype=np.float32)  # Dummy depth map
+    depth_b = np.full((480, 640), 100.0, dtype=np.float32)  # Dummy depth map
+    pose_a = np.eye(4, dtype=np.float32)
+    pose_b = np.eye(4, dtype=np.float32)
+    # pose_b[0, 3] = -1.0  # Shift camera b by -1 unit in x direction
+    # pose_b[1, 3] = -1.0  # Shift camera b by -1 unit in y direction
+    pose_b[2, 3] = -1.0  # Shift camera b by -1 unit in z direction
+    K = np.array([[500, 0, 320], [0, 500, 240], [0, 0, 1]], dtype=np.float32)
+
+    num_bisections, F_0_1, F_1_0, valid_mask_0_1, valid_mask_1_0 = calculateBiOpticalFlowMagnitude(depth_a, depth_b, pose_a, pose_b, K)
+
+    print(f"Number of bisections based on maximum flow magnitude: {num_bisections}")
+
+    # Visualize optical flow
+    plt.figure(figsize=(12, 6))
+
+    plt.subplot(1, 2, 1)
+    plt.title("Optical Flow from A to B")
+    _flow = flow_vis.flow_to_color(F_1_0)
+    _flow[~valid_mask_1_0] = 0
+    plt.imshow(_flow)
+
+    plt.subplot(1, 2, 2)
+    plt.title("Optical Flow from B to A")
+    _flow = flow_vis.flow_to_color(F_0_1)
+    _flow[~valid_mask_0_1] = 0
+    plt.imshow(_flow)
+
+    plt.show()
+    
+    
