+from tqdm import tqdm
+from src.utils.loss_utils import psnr_score, ssim_score
+import torch
+
+def mean_error(y_input, y_target):
+    mask = (y_input > 0) & (y_target > 0) & (~np.isnan(y_target)) 
+    y_input = y_input[mask]
+    y_target = y_target[mask]    
+    abs_diff = np.abs(y_target-y_input)
+    return abs_diff.mean()
+
+def rms_linear(y_input, y_target):
+    mask = (y_input > 0) & (y_target > 0) & (~np.isnan(y_target)) 
+    y_input = y_input[mask]
+    y_target = y_target[mask]     
+    abs_diff = np.abs(y_target-y_input)
+    return np.sqrt((abs_diff**2).mean())
+
+def th_delta_error(y_input, y_target, th=1.25):
+    eps = 1e-5
+    mask = (y_input > 0) & (y_target > 0) & (~np.isnan(y_target)) 
+    y_input = y_input[mask]
+    y_target = y_target[mask]    
+    ratio = np.max(np.stack([y_target/(y_input+eps),y_input/(y_target+eps)]), axis=0)
+    return np.mean(ratio <= th)
+
+def normalized_depth_scale_and_shift(
+    prediction, target, mask, min_quantile = 0.2, max_quantile = 0.9
+):
+    """
+    More info here: https://arxiv.org/pdf/2206.00665.pdf supplementary section A2 Depth Consistency Loss
+    This function computes scale/shift required to normalizes predicted depth map,
+    to allow for using normalized depth maps as input from monocular depth estimation networks.
+    These networks are trained such that they predict normalized depth maps.
+
+    Solves for scale/shift using a least squares approach with a closed form solution:
+    Based on:
+    https://github.com/autonomousvision/monosdf/blob/d9619e948bf3d85c6adec1a643f679e2e8e84d4b/code/model/loss.py#L7
+    Args:
+        prediction: predicted depth map
+        target: ground truth depth map
+        mask: mask of valid pixels
+    Returns:
+        scale and shift for depth prediction
+    """
+
+    B, _, _, _ = prediction.shape
+    
+    if min_quantile > 0.0 or max_quantile < 1.0:
+        # compute quantiles
+        target_dtype = target.dtype
+        min_quantile = torch.quantile(target.float(), min_quantile).to(target_dtype)
+        max_quantile = torch.quantile(target.float(), max_quantile).to(target_dtype)
+        mask = (target >= min_quantile) * (target <= max_quantile) * mask
+
+    # system matrix: A = [[a_00, a_01], [a_10, a_11]]
+    a_00 = torch.sum(mask * prediction * prediction, (1, 2, 3))
+    a_01 = torch.sum(mask * prediction, (1, 2, 3))
+    a_11 = torch.sum(mask, (1, 2, 3))
+
+    # right hand side: b = [b_0, b_1]
+    b_0 = torch.sum(mask * prediction * target, (1, 2, 3))
+    b_1 = torch.sum(mask * target, (1, 2, 3))
+
+    # solution: x = A^-1 . b = [[a_11, -a_01], [-a_10, a_00]] / (a_00 * a_11 - a_01 * a_10) . b
+    scale = torch.zeros_like(b_0)
+    shift = torch.zeros_like(b_1)
+
+    det = a_00 * a_11 - a_01 * a_01
+    valid = (det != 0)
+
+    scale[valid] = (a_11[valid] * b_0[valid] - a_01[valid] * b_1[valid]) / det[valid]
+    shift[valid] = (-a_01[valid] * b_0[valid] + a_00[valid] * b_1[valid]) / det[valid]
+
+    return scale.reshape(B,1,1,1), shift.reshape(B,1,1,1)
+
+def evaluate_rendered_images(gt_img_path, gt_depth_path, render_img_path, render_depth_path, scale_depth=False):
+    # Load ground-truth image and depth
+    gt_img = cv2.imread(gt_img_path)
+    gt_depth = cv2.imread(gt_depth_path, cv2.IMREAD_ANYDEPTH) / 1000.0  # Convert depth to meters
+
+    # Load rendered image and depth
+    render_img = cv2.imread(render_img_path, cv2.IMREAD_UNCHANGED)
+    # remove alpha channel if present, convert grayscale to BGR
+    if render_img.ndim == 3 and render_img.shape[2] == 4:
+        render_img = render_img[:, :, :3]
+    elif render_img.ndim == 2:
+        render_img = cv2.cvtColor(render_img, cv2.COLOR_GRAY2BGR)
+    render_depth = np.load(render_depth_path)
+
+    if render_depth.ndim == 3 and render_depth.shape[2] == 1:
+        render_depth = render_depth[:, :, 0]
+    elif render_depth.ndim == 3 and render_depth.shape[2] == 4:
+        render_depth = render_depth[:, :, 0]
+
+    # HW3 to 3HW conversion
+    gt_img = np.transpose(gt_img, (2, 0, 1))
+    render_img = np.transpose(render_img, (2, 0, 1))
+
+    #print(f"shapes: gt_img {gt_img.shape}, render_img {render_img.shape}, gt_depth {gt_depth.shape}, render_depth {render_depth.shape}")
+
+    # Resize rendered image to match ground-truth image resolution
+    render_img = cv2.resize(render_img.transpose(1, 2, 0), (gt_img.shape[2], gt_img.shape[1]), interpolation=cv2.INTER_LINEAR).transpose(2, 0, 1)
+
+    # Resize rendered depth to match ground-truth depth resolution
+    render_depth = cv2.resize(render_depth, (gt_depth.shape[1], gt_depth.shape[0]), interpolation=cv2.INTER_NEAREST)
+
+    # convert images to torch tensors
+    gt_img = torch.from_numpy(gt_img.astype(np.float32) / 255.0).cuda()
+    render_img = torch.from_numpy(render_img.astype(np.float32) / 255.0).cuda()
+
+    if scale_depth:
+        # apply scale and shift to the predicted depth maps
+        gt_depth_tensor = torch.from_numpy(gt_depth.astype(np.float32)).unsqueeze(0).unsqueeze(0).cuda()
+        render_depth_tensor = torch.from_numpy(render_depth.astype(np.float32)).unsqueeze(0).unsqueeze(0).cuda()
+
+        valid_mask = (gt_depth_tensor > 0).float()
+        scale, shift = normalized_depth_scale_and_shift(render_depth_tensor, gt_depth_tensor, valid_mask)
+
+        print(f"Applying scale {scale.item():.4f} and shift {shift.item():.4f} to rendered depth map.")
+
+        render_depth_tensor = render_depth_tensor * scale + shift
+        render_depth = render_depth_tensor.squeeze().cpu().numpy()
+
+    # Compute metrics
+    psnr = psnr_score(gt_img, render_img).cpu().squeeze().numpy()
+    ssim = ssim_score(gt_img, render_img).cpu().squeeze().numpy()
+
+    mae = mean_error(render_depth, gt_depth)
+    rmse = rms_linear(render_depth, gt_depth)
+    th1 = th_delta_error(render_depth, gt_depth, th=1.25)
+    th2 = th_delta_error(render_depth, gt_depth, th=1.25**2)
+    th3 = th_delta_error(render_depth, gt_depth, th=1.25**3)
+
+    return {
+        'psnr': psnr,
+        'ssim': ssim,
+        'mae': mae,
+        'rmse': rmse,
+        'th1': th1,
+        'th2': th2,
+        'th3': th3
+    }
+
+if __name__ == "__main__":
+    parser = argparse.ArgumentParser(description="Evaluate Rendered Images and Depths.")
+    parser.add_argument('-g', '--gt_paths', type=str, nargs='+', help='Paths to the ground-truth dataset directories.')
+    parser.add_argument('-r', '--render_paths', type=str, nargs='+', help='Paths to the rendered dataset directories.')
+    parser.add_argument('-o', '--output_csv', type=str, help='Path to save the evaluation results CSV.')
+    parser.add_argument('--scale_depth', action='store_true', help='Whether to apply scale and shift to the predicted depth maps before evaluation.')
+
+    args = parser.parse_args()
+
+    gt_paths = args.gt_paths
+    render_paths = args.render_paths
+    output_csv = args.output_csv
+    scale_depth = args.scale_depth
+    if len(gt_paths) != len(render_paths):
+        raise ValueError(f"Number of ground-truth paths must match number of render paths ({len(gt_paths)} != {len(render_paths)})")
+
+    results = []
+
+    # iterate over paired sequences
+    for gt_path, render_path in zip(gt_paths, render_paths):
+        imgs = sorted([f for f in os.listdir(os.path.join(gt_path, 'images')) if f.lower().endswith('.jpg') or f.endswith('.JPG')])
+        depths = sorted([f for f in os.listdir(os.path.join(gt_path, 'depths')) if f.endswith('.png')])
+
+        for img_name in tqdm(imgs, desc=f"Processing {os.path.basename(gt_path)}"):
+            base = os.path.splitext(img_name)[0]
+            gt_img_path = os.path.join(gt_path, 'images', img_name)
+            gt_depth_path = os.path.join(gt_path, 'depths', base + '.png')
+
+            if 'rendering' in os.listdir(render_path):
+                render_img_path_a = os.path.join(render_path, 'rendering', base + '.JPG')
+                render_img_path_b = os.path.join(render_path, 'rendering', base + '.jpg')
+                render_depth_path = os.path.join(render_path, 'rendering', base + '.npy')
+            elif 'renders' in os.listdir(render_path):
+                render_img_path_a = os.path.join(render_path, 'renders', base + '.JPG')
+                render_img_path_b = os.path.join(render_path, 'renders', base + '.jpg')
+                render_depth_path = os.path.join(render_path, 'renders', base + '.npy')
+            else:
+                render_img_path_a = os.path.join(render_path, base + '.JPG')
+                render_img_path_b = os.path.join(render_path, base + '.jpg')
+                render_depth_path = os.path.join(render_path, base + '.npy')
+
+            # if not os.path.exists(gt_img_path) or not os.path.exists(gt_depth_path):
+            #     print(f"Skipping {base}: missing ground-truth files")
+            #     continue
+
+            if not os.path.exists(gt_img_path):
+                print(f"Skipping {gt_img_path}: missing ground-truth image")
+                continue
+
+            if not os.path.exists(gt_depth_path):
+                print(f"Skipping {gt_depth_path}: missing ground-truth depth")
+                continue
+
+            # if (not os.path.exists(render_img_path_a) and not os.path.exists(render_img_path_b)) or not os.path.exists(render_depth_path):
+            #     print(f"Skipping {base}: missing rendered files")
+            #     continue
+
+            if not os.path.exists(render_img_path_a) and not os.path.exists(render_img_path_b):
+                print(f"Skipping {render_img_path_a} ({os.path.basename(render_img_path_b)}): missing rendered image")
