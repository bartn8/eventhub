+                            log_images = log_images + _log_images
+                            timestamps = timestamps + _timestamps
+                            
+                            events_len_acc += _accumulate_events(esim, logger, log_images, timestamps, args.duration, num_noise_events=args.num_noise_events)
+                            
+                        if events_len_acc < args.min_events_per_frame:
