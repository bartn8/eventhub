+# Analisi delle pose tramite Alpha-Shape
+import numpy as np
+import alphashape
+from shapely.geometry import Polygon
+import trimesh
+from scipy.spatial import cKDTree
+import matplotlib.pyplot as plt
+import glob
+import os
+
+
+def save_traj_plot(id, poses_path, mesh_path, max_alpha=20):
+
+    #f"/leonardo_work/EUHPC_D24_081/datasets/scannet++_train_nvs_svraster/{ID}/svraster_inputs/poses.npy"
+    _poses_path = os.path.join(poses_path, id, "svraster_inputs", "poses.npy")
+    #f"/leonardo_work/EUHPC_D24_081/datasets/scannet++_train_nvs/{ID}/scans/mesh_aligned_0.05.ply"
+    _mesh_path = os.path.join(mesh_path, id, "scans", "mesh_aligned_0.05.ply")
+    
+    _output_path_plot = os.path.join(poses_path, id, "svraster_inputs", "traj_plot.png")
+    _output_path_idxs = os.path.join(poses_path, id, "svraster_inputs", "boundary_pose_indices.txt")
+    
+    if os.path.exists(_output_path_plot) and os.path.exists(_output_path_idxs):
+        print(f"Files {_output_path_plot} and {_output_path_idxs} already exist. Skipping.")
+        return
+
+    # Carica le pose (N,4,4)
+    poses = np.load(_poses_path)  # (N, 4, 4)
+    mesh = trimesh.load(_mesh_path)
+
+    trans = poses[:, :3, 3]
+    pts = trans[:, :2]
+    pts_min = pts.min(0)
+    pts_max = pts.max(0)
+    # Normalizza i punti nell'intervallo [0, 1]
+    pts = (pts - pts_min) / (pts_max - pts_min)  # Normalizza in [0, 1]
+    
+    current_alpha = max_alpha
+    while current_alpha >= 0:
+        shape = alphashape.alphashape(pts, current_alpha)
+        if isinstance(shape, Polygon):
+            break
+        current_alpha -= 1
+    alpha = current_alpha
+    print(f"Computed alpha-shape with alpha={alpha} for {id}")
+    # Visualizza le pose e il contorno alpha-shape
+
+    if isinstance(shape, Polygon):
+        boundary_coords = np.array(shape.exterior.coords * (pts_max - pts_min) + pts_min)  # Denormalizza i punti
+        tree = cKDTree(pts * (pts_max - pts_min) + pts_min)  # Usa i punti denormalizzati per l'albero
+        _, idxs = tree.query(boundary_coords, k=1)
+        # do not sort idxs: they are already in order following the alpha-shape boundary
+        boundary_poses = poses[idxs]
+        np.savetxt(_output_path_idxs, idxs, fmt='%d')
+        print(f"Saved boundary pose indices to {_output_path_idxs}")
+        
+        # cut mesh with a xy plane where z is the mean of the mesh vertices
+        poses_t = np.array([pose[:3,3] for pose in poses])
+        # Invertiamo x e y per allineare le coordinate dei pose con quelle del mesh
+        inv_poses_t = np.array([[pose[1], pose[0], pose[2]] for pose in poses_t])
+        b_poses_t = np.array([(pose)[:3,3] for pose in boundary_poses])
+        inv_b_poses_t = np.array([[pose[1], pose[0], pose[2]] for pose in b_poses_t])
+
+        z_mean = mesh.vertices[:,2].mean()
+        plane_origin = np.array([0,0,z_mean])
+        plane_normal = np.array([0,0,1])
+        _, face_indices = trimesh.intersections.mesh_plane(mesh, plane_normal, plane_origin, return_faces=True)
+
+        if len(face_indices) > 0:
+            plt.figure(figsize=(8*4,8*4))
+            
+            plt.plot(inv_b_poses_t[:,0], inv_b_poses_t[:,1], 'bo', label='Boundary Poses Inv')
+            plt.plot(inv_poses_t[:,0], inv_poses_t[:,1], 'y.', markersize=2, label='All Poses Inv')
+            
+            plt.plot(boundary_poses[:,1, 3], boundary_poses[:,0, 3], 'k-', lw=2, label='Alpha-shape boundary')
+            for i, pose in enumerate(boundary_poses):
+                if i % 10 != 0:
+                    continue
+                y, x = pose[0, 3], pose[1, 3]
+                plt.text(x, y, str(i), fontsize=12, color='red', ha='center', va='center')
+            
+            
+            for face_i in face_indices:
+                plt.plot(mesh.vertices[mesh.faces[face_i],0], mesh.vertices[mesh.faces[face_i],1], 'r-', lw=1, alpha=0.3)
+            
+            
+            plt.legend()
+            plt.axis('equal')
+            plt.title(f'Poses and Mesh Cross-Section (alpha={alpha})')
+            plt.tight_layout()
+            plt.savefig(_output_path_plot)
+            plt.close()
+            print(f"Saved trajectory plot to {_output_path_plot}")
+            return
+        else:
+            print(f"Could not generate plot for {id}, no mesh cross-section found.")
+    else:        
+        print(f"Could not generate plot for {id}, no valid alpha-shape found.")
+
+if __name__ == "__main__":
+    import argparse
+    
+    parser = argparse.ArgumentParser(description="Generate and save trajectory plots for multiple datasets")
+    parser.add_argument("poses_path", type=str, help="Path to the directory containing datasets with poses.npy")
+    parser.add_argument("mesh_path", type=str, help="Path to the directory containing datasets with mesh files")
+    parser.add_argument("--max_alpha", type=float, default=20, help="Alpha value for alpha-shape computation")
+    args = parser.parse_args()
+
+    ids = glob.glob(os.path.join(args.poses_path, "*"))
+    ids = [os.path.basename(id) for id in ids]
+
+    for id in ids:
+        save_traj_plot(id, args.poses_path, args.mesh_path, max_alpha=args.max_alpha)
