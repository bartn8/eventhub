+    def color_gradient(n):
+        """Return n RGB colors from a matplotlib colormap (viridis)"""
+        cmap = cm.get_cmap("viridis")
+        return [cmap(i / max(n - 1, 1))[:3] for i in range(n)]
+
+    def create_colored_frustum(pose, size=0.1, color=(1, 0, 0), opacity=1.0):
+        """Create a camera frustum painted with a uniform color and opacity"""
+        # Create camera frustum with default intrinsics
