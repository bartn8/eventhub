+def _rgb_to_log_image(rgb: torch.Tensor, gauss_blur_kernel: int = 0, gauss_noise_std: float = 0.0, gain: float = 1.0, offset: float = 0.0, invert: bool = False) -> torch.Tensor:
+    rgb = rgb.unsqueeze(0)
+    if gauss_blur_kernel > 1 and gauss_blur_kernel % 2 == 1:
+        sigma = 0.3 * ((gauss_blur_kernel - 1) * 0.5 - 1) + 0.8
+        rgb = gaussian_blur2d(rgb, (gauss_blur_kernel, gauss_blur_kernel), (sigma, sigma))
+        
+    if gauss_noise_std > 0.0:
+        noise = torch.randn_like(rgb) * gauss_noise_std
+        rgb = rgb + noise
+        
+    rgb = rgb * gain + offset    
+    rgb = torch.clamp(rgb, 0.0, 1.0)
+    rgb = 1.0 - rgb if invert else rgb
+    
+    # global DEBUG_COUNTER
+    # cv2.imwrite(f"/leonardo_scratch/fast/IscrC_VFM4Ev/projects/ev-nerf-stereo/tmp/debug/{DEBUG_COUNTER:09}.png", (rgb[0].cpu().numpy().transpose(1, 2, 0) * 255).astype(np.uint8))
+    # DEBUG_COUNTER += 1
+        
+    gray = rgb_to_grayscale(rgb)
+    # log_image = lin_log_norm(gray)
+    log_image = log_norm(gray)
+    return log_image.squeeze(0)
+
+def _render_fn(pose, voxel_model, fovx, fovy, width, height, output_depth=True, output_T=True):
+    cam = MiniCam(
+        c2w=pose,
+        fovx=fovx, fovy=fovy,
+        width=width, height=height)
+    
+    # Render the next pose
+    with torch.no_grad():
+        return voxel_model.render(cam, output_depth=output_depth, output_T=output_T)
+
+def _recursive_render_fn(voxel_model, fovx, fovy, width, height, pose_interpolator, t0, t1, K, shift, num_bisections=-1, gauss_blur_kernel=0, gauss_noise_std=0.0, gain=1.0, offset=0.0, invert=False, invert_t=False):
+    # Implement the recursive rendering function here
+    if num_bisections == 0:
+        return [], []
+    
+    dt = (t0+t1)/2
+
+    pose_dt = pose_interpolator.interpolate(dt, shift=shift, invert_t=invert_t)        
+    render_pkg_dt = _render_fn(pose_dt, voxel_model, fovx, fovy, width, height, output_depth=True, output_T=True)
+
+    # rendering_log = lin_log_norm(rgb_to_grayscale(render_pkg_dt['color']))
+    rendering_log = _rgb_to_log_image(render_pkg_dt['color'], gauss_blur_kernel=gauss_blur_kernel, gauss_noise_std=gauss_noise_std, gain=gain, offset=offset, invert=invert)
+
+    if num_bisections < 0:
+        pose_t0 = pose_interpolator.interpolate(t0, shift=shift, invert_t=invert_t)
+        render_pkg_t0 = _render_fn(pose_t0, voxel_model, fovx, fovy, width, height, output_depth=True, output_T=True)
+
+        depth_t0 = render_pkg_t0['depth'][[0]].squeeze().cpu().numpy()
+        depth_dt = render_pkg_dt['depth'][[0]].squeeze().cpu().numpy()
+
+        num_bisections, *_ = calculateBiOpticalFlowMagnitude(depth_t0, depth_dt, pose_t0, pose_dt, K, c2w=True)
+
+        if num_bisections == 0:
+            return [rendering_log], [(t0 + t1) / 2]
+
+    left_log_images, left_timestamps = _recursive_render_fn(voxel_model, fovx, fovy, width, height, pose_interpolator, t0, dt, K, shift, num_bisections=num_bisections-1, gauss_blur_kernel=gauss_blur_kernel, gauss_noise_std=gauss_noise_std, gain=gain, offset=offset, invert=invert, invert_t=invert_t)
+    right_log_images, right_timestamps = _recursive_render_fn(voxel_model, fovx, fovy, width, height, pose_interpolator, dt, t1, K, shift, num_bisections=num_bisections-1, gauss_blur_kernel=gauss_blur_kernel, gauss_noise_std=gauss_noise_std, gain=gain, offset=offset, invert=invert, invert_t=invert_t)
+
+    timestamps = left_timestamps + [dt] + right_timestamps
+    log_images = left_log_images + [rendering_log] + right_log_images
+
+    return log_images, timestamps
+
+def _convert_ts(timestamps: Union[list[float], float], duration: float) -> Union[list[int], int]:
+    if isinstance(timestamps, float):
+        return int(timestamps * duration * 1e9) # Convert to ns
+    elif isinstance(timestamps, list):
+        return [int(ts * duration * 1e9) for ts in timestamps] # Convert to ns
+    else:
+        raise ValueError("Timestamps must be a float or a list of floats.")
+
+def _accumulate_events(esim: esim_torch.ESIM, logger: MyRenderLogger, log_images: list, timestamps: list, duration: float, skip_save: bool = False, num_noise_events: int = 0):
+    events_len = 0
+    
+    # Assume temporal order
+    # assert all(timestamps[i] <= timestamps[i+1] for i in range(len(timestamps)-1)), "Timestamps must be in ascending order."
+    timestamps = [_convert_ts(timestamps[i], duration) for i in range(len(timestamps))]
+    
+    # Ensure timestamps are sorted
+    # sorted_indices = np.argsort(timestamps)
+    # log_images = [log_images[i] for i in sorted_indices]
+    # timestamps = [_convert_ts(timestamps[i], duration) for i in sorted_indices]
+
+    for i in range(len(log_images)):
+        _log_image = log_images[i].to(rendering_log.device)  # [1, H, W]
+        
+        # _tmp_log_image = _log_image.squeeze().cpu().numpy()
+        # _tmp_log_image = (_tmp_log_image - _tmp_log_image.min()) / (_tmp_log_image.max() - _tmp_log_image.min() + 1e-8) * 255
+        # cv2.imwrite(f"/home/luca/Scrivania/projects/ev-nerf-stereo/tmp/frames/frame_{_accumulate_events.debug_counter:06d}.png", _tmp_log_image.astype(np.uint8))
+        # _accumulate_events.debug_counter += 1
+        
+        _timestamp = torch.tensor(timestamps[i], dtype=torch.int64).to(rendering_log.device)
+
+        # Events timestamps between current pose and next pose
+        # Always render events otherwise RGB left will be different....
+        events = esim.forward(_log_image, _timestamp)
+
+        if num_noise_events > 0 and events is not None and len(events['t']) > 0:
+            # num_noise_events = int(len(events['t']) * uniform_noise_perc)
+            num_noise_events = random.randint(0, 2*num_noise_events)
+            noise_x = torch.randint(0, rendering_log.shape[2], (num_noise_events,), device=rendering_log.device)
+            noise_y = torch.randint(0, rendering_log.shape[1], (num_noise_events,), device=rendering_log.device)
+            _min_ts, _max_ts = events['t'][0], events['t'][-1]
+            noise_t = torch.randint(_min_ts, _max_ts + 1, (num_noise_events,), device=rendering_log.device)
+            # Esim polarity is -1 or 1
+            noise_p = torch.randint(0, 2, (num_noise_events,), device=rendering_log.device) * 2 - 1
+            
+            events['x'] = torch.cat([events['x'], noise_x], dim=0)
+            events['y'] = torch.cat([events['y'], noise_y], dim=0)
+            events['t'] = torch.cat([events['t'], noise_t], dim=0)
+            events['p'] = torch.cat([events['p'], noise_p], dim=0)
+            
+            # Sort events by timestamp
+            sorted_indices = torch.argsort(events['t'])
+            events['x'] = events['x'][sorted_indices]
+            events['y'] = events['y'][sorted_indices]
+            events['t'] = events['t'][sorted_indices]
+            events['p'] = events['p'][sorted_indices]
+
+        # Save events (H5 file)
+        if not skip_save:
+            events_len += len(events['t']) if events is not None else 0
+            logger.log_events_accumulate(events)
+        
+    return events_len
+
