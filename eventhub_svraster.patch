+    parser.add_argument('--render_choices_center', nargs='+', default=list(OUTPUT_SET),
+                        help=f'List of render choices for center stream. Available options: {(", ".join(OUTPUT_SET))}. Default: all.')
+    parser.add_argument('--render_choices_right', nargs='+', default=list(OUTPUT_SET),
