+from typing import Callable, Optional
+import numpy as np
+from scipy.interpolate import make_interp_spline, make_lsq_spline
+
+
+def _monotonic_fn_linear(t: float) -> float:
+    return t
+
+def _monotonic_fn_cos2(t: float, freq_hz: float = 16, phase: float = 0) -> float:
+    # integral of cos^2(ax+q)dx from 0 to t = (2 a t - sin(2 q) + sin(2 (q + a t)))/(4 a)
+    # t in [0,1]
+    a = freq_hz * 2 * np.pi
+    q = np.deg2rad(phase)
+    _int_fn = lambda t: (2 * a * t - np.sin(2 * q) + np.sin(2 * (q + a * t))) / (4 * a)
+    return _int_fn(t) / _int_fn(1.0)
+
+def _monotonic_fn_sin2(t: float, freq_hz: float = 16, phase: float = 0) -> float:
+    # integral of sin^2(ax+q)dx from 0 to t = (2 a t + sin(2 q) - sin(2 (q + a t)))/(4 a)
+    # t in [0,1]
+    a = freq_hz * 2 * np.pi
+    q = np.deg2rad(phase)
+    _int_fn = lambda t: (2 * a * t + np.sin(2 * q) - np.sin(2 * (q + a * t))) / (4 * a)
+    return _int_fn(t) / _int_fn(1.0)
+
+def _monotonic_fn_gamma(t: float, gamma: float = 2) -> float:
+    return t ** gamma
+
+VELOCITY_DICT = {
+    "linear": _monotonic_fn_linear,
+    "cos2": _monotonic_fn_cos2,
+    "sin2": _monotonic_fn_sin2,
+    "gamma": _monotonic_fn_gamma,
+}
+
+def parse_velocity_fn(velocity_arg: list) -> Callable:
+    velocity_type = velocity_arg[0]
+    assert velocity_type in VELOCITY_DICT, f"Unknown velocity_type '{velocity_type}'. Supported types: {list(VELOCITY_DICT.keys())}"
+    velocity_args = [float(v) for v in velocity_arg[1:]] if len(velocity_arg) > 1 else []
+    velocity_fn = VELOCITY_DICT.get(velocity_type, _monotonic_fn_linear)
+    return lambda t: velocity_fn(t, *velocity_args)
+
+def _compute_custom_weights(poses: list) -> np.ndarray:
+    """
+    Calcola pesi personalizzati per make_lsq_spline basati sulla deviazione 
+    dalla linea tra posa precedente e successiva.
+    
+    Args:
+        poses: Lista di pose 4x4
+        
+    Returns:
+        Array di pesi per ogni posa (stesso numero di elementi di poses)
+    """
+    if len(poses) <= 2:
+        return np.ones(len(poses))
+    
+    # Estrai posizioni 2D (drop componente z)
+    pos_2d = np.array([pose[:2, 3] for pose in poses])  # Shape: (n_poses, 2)
+    weights = np.ones(len(poses))
+    
+    # Disugualianza triangolare
+    for i in range(1, len(poses) - 1):
+        # Posa corrente
+        current_pose = pos_2d[i]
+        
+        # Posa precedente e successiva
+        prev_pose = pos_2d[i - 1]
+        next_pose = pos_2d[i + 1]
+        
+        # weights[i] = max(np.linalg.norm(next_pose - prev_pose) - (np.linalg.norm(current_pose - prev_pose) + np.linalg.norm(current_pose - next_pose)), 0)
+        weights[i] = np.linalg.norm(current_pose - prev_pose) + np.linalg.norm(current_pose - next_pose)
+            
+    weights = weights / np.max(weights)
+    weights = np.clip(weights, 0.1, 1.0)           
+    
+    return weights
+
+# def gravity_from_positions_pca(poses4x4):
+#     """
+#     Fit plane to camera centers and return unit normal (gravity direction).
+#     poses4x4: (N,4,4)
+#     """
+#     Ts = np.asarray([P[:3,3] for P in poses4x4])
+#     mu = Ts.mean(axis=0)
+#     centered = Ts - mu
+#     U, S, Vt = np.linalg.svd(centered, full_matrices=False)
+#     # smallest principal component is last row of Vt
+#     normal = Vt.T[:, -1]
+#     return -normal / np.linalg.norm(normal)
+
+
+class PoseInterpolator:
+    def __init__(self, 
+                 poses: list, 
+                 traj_fn: Optional[Callable] = None,
+                 shift: Optional[float] = None,
+                 k_spline: int = 3,
+                 bc_type: Optional[str] = None,
+                 lsq: bool = True,
+                 lsq_smoothness: int = 3,
+                 m_weight: float = 0.0,
+                 velocity_fn: Optional[Callable] = None,
+                 use_custom_weights: bool = False,
+                 spline_offset: float = 0.0,
+                 norm_min: float = 0.0,
+                 norm_max: float = 1.0) -> None:
+        assert poses is not None, "Please provide poses to interpolate."
+        #assert len(poses) > 1
+        
+        if not isinstance(poses, (list, tuple)):
+            poses = [poses]
+        
+        assert all(isinstance(pose, np.ndarray) and pose.shape == (4, 4) for pose in poses), "Each pose must be a 4x4 numpy array."
+        
+        self.poses = list(poses) # list of 4x4 numpy arrays
+        # self.gravity_vector = gravity_from_positions_pca(poses)
+        # print(f"Estimated gravity vector: {self.gravity_vector}")
+        self.gravity_vector = np.array([0, 0, 1], dtype=np.float64)  # Scannet gravity vector
+        
+        self.traj_fn = traj_fn
+        self.shift = shift
+        self.m_weight = max(0.0, min(1.0, m_weight))
+        self.velocity_fn = _monotonic_fn_linear if velocity_fn is None else velocity_fn
+        self.spline_offset = spline_offset
+        # self.n_centroids = max(1, n_centroids)
+        self.n_centroids = 1
+        self.norm_min = norm_min
+        self.norm_max = norm_max
+
+        pos_lst = np.stack([pose[:3, 3].astype(np.float64) for pose in poses])
+        lookat_lst = np.stack([pose[:3, 2].astype(np.float64) for pose in poses])
+        right_lst = np.stack([pose[:3, 0].astype(np.float64) for pose in poses])
+
+        if len(poses) == 1:
+            self.pos_interp_f = lambda t: pos_lst[0]
+            self.lookat_interp_f = lambda t: lookat_lst[0]
+            self.right_interp_f = lambda t: right_lst[0]
+            return
+
+        ts = np.linspace(0, 1, len(poses), dtype=np.float64, endpoint=True)
+        self.ts = ts
+        
+        if lsq:
+            # Define knot vector: must satisfy Schoenberg-Whitney conditions
+            # Interior knots (without boundary multiplicity)
+            # // 3 instead of // 2 for more smoothness
+            n_internal = max(len(ts) // lsq_smoothness, k_spline + 1)  # number of internal knots
+            t_internal = np.linspace(ts[0], ts[-1], n_internal, dtype=np.float64, endpoint=True)
+
+            # Full knot vector (add k boundary knots at each side)
+            knots = np.concatenate(([ts[0]] * k_spline, t_internal, [ts[-1]] * k_spline))
+
+            # Calcola pesi personalizzati se richiesto
+            if use_custom_weights:
+                weights = _compute_custom_weights(poses)
+                print(f"Using custom weights for LSQ spline: min={weights.min():.3f}, max={weights.max():.3f}, mean={weights.mean():.3f}")
+            else:
+                weights = None
+
+            try:
+                self.pos_interp_f = make_lsq_spline(ts, pos_lst, knots, k_spline, w=weights)
+                self.lookat_interp_f = make_lsq_spline(ts, lookat_lst, knots, k_spline, w=weights)
+                self.right_interp_f = make_lsq_spline(ts, right_lst, knots, k_spline, w=weights)
+            except Exception as e:
+                print(f"LSQ spline failed with custom weights, falling back to regular spline: {e}")
+                # Fall back to regular spline
+                lsq = False
+
+        if not lsq:
+            self.pos_interp_f = make_interp_spline(ts, pos_lst, k=k_spline, bc_type=bc_type)
+            self.lookat_interp_f = make_interp_spline(ts, lookat_lst, k=k_spline, bc_type=bc_type)
+            self.right_interp_f = make_interp_spline(ts, right_lst, k=k_spline, bc_type=bc_type)
+            
+        if spline_offset != 0.0:
+            # Alternative 1: Offset geometrico lungo la normale (funziona meglio per traiettorie curve)
+            # self.pos_interp_f = self._create_offset_spline(self.pos_interp_f, spline_offset, k_spline, bc_type)
+            
+            # Alternative 2: Offset dal centroide
+            # Calcola centroide usando self.pos_interp_f
+            # sampled_pos_list = [self.pos_interp_f(t) for t in np.linspace(0, 1, 1000)]
+            # self.centroids = [np.mean(sub_array, axis=0) for sub_array in np.array_split(sampled_pos_list, self.n_centroids)]
+            self.centroid = np.mean([self.pos_interp_f(t) for t in np.linspace(0, 1, 1000)], axis=0)
+
+    def get_camera_poses_timestamps(self) -> list:
+        return list(self.ts)
+
+    def __call__(self, t: float, traj_fn: Optional[Callable] = None, shift: Optional[float] = None, m_weight: Optional[float] = None, invert_t: bool = False) -> np.ndarray:
+        return self.interpolate(t, traj_fn=traj_fn, shift=shift, m_weight=m_weight, invert_t=invert_t)
+    
+    def _applyStereoPose(self, pose: np.ndarray, shift: float):
+        stereo_pose = np.eye(4)
+        stereo_pose[0, 3] = shift
+        return np.linalg.inv(stereo_pose @ np.linalg.inv(pose)).astype(np.float32)
+
+    def _align_pose_z_to_motion(self, pose_fn: Callable, t: float, dt: float = 1e-6, a: float = 0.0, eps: float = 1e-3) -> np.ndarray:
+        """
+        Rotate the pose's z-axis toward the motion direction at time t.
+
+        - a in [0, 1]: 0 -> keep original view z; 1 -> fully align to velocity dir.
+        - Uses original axes to build a right-handed frame (no arbitrary world-up).
+        """
+        pose = pose_fn(t)
+        R = pose[:3, :3]
+        p = pose[:3, 3].copy()
+
+        vel = np.zeros(3, dtype=np.float64)
+        n_vel = 0.0
+        _dt = dt
+
+        while n_vel < eps and (t - _dt >= 0 or t + _dt <= 1.0):
+            _dt += dt
+            
+            # Finite-difference velocity
+            if t + _dt <= 1.0:
+                p_dt = pose_fn(t + _dt)[:3, 3]
+                vel = p_dt - p
+            else:
+                p_dt = pose_fn(t - _dt)[:3, 3]
+                vel = p - p_dt
+            
+            n_vel = np.linalg.norm(vel)
+            
+        if n_vel < eps:
+            #print(f"No motion detected ({n_vel} < {eps})")
+            motion_dir = R[:, 2]  # fallback: keep original z-axis
+        else:
+            motion_dir = vel / n_vel
+        
+        # # Avoid opposite motion: ensure motion_dir is in same hemisphere as z_orig 
+        z_orig = R[:, 2]        
+        # dot = np.dot(z_orig, motion_dir)
+        # v_parallel = dot * z_orig
+        # v_perp = motion_dir - v_parallel
+
+        # if dot < 0:
+        #     motion_dir = -v_parallel + v_perp
+
+        motion_dir /= np.linalg.norm(motion_dir)
+
+        # Interpolate z-axis and normalize (fallback if near cancellation)
+        a = float(np.clip(a, 0.0, 1.0))
+        z_interp = (1.0 - a) * z_orig + a * motion_dir
+        n_z = np.linalg.norm(z_interp)
+
+        # if n_z < eps:
+        #     #print(f"Motion is opposite to original z-axis ({n_z} < {eps})")
+        #     return pose.copy()  # motion is opposite to original z-axis
+
+        z_interp = z_interp / n_z
+        
+        # Build a right-handed frame using gravity as world-up
+        world_y = self.gravity_vector
+        z_interp = z_interp
+        x_new = np.cross(world_y, z_interp)
+        x_new /= np.linalg.norm(x_new)
+        
+        y_new = np.cross(z_interp, x_new)
+        y_new /= np.linalg.norm(y_new)
+        
+        R_new = np.column_stack((x_new, y_new, z_interp))
+
+        new_pose = np.eye(4, dtype=np.float64)
+        new_pose[:3, :3] = R_new
+        new_pose[:3, 3] = p
+        return new_pose
+
+    def interpolate(self, t: float, traj_fn: Optional[Callable] = None, shift: Optional[float] = None, m_weight: Optional[float] = None, invert_t: bool = False) -> np.ndarray:
+        assert 0 <= t <= 1, "t must be in the range [0, 1]"
+        
+        t = (t - self.norm_min) / (self.norm_max - self.norm_min)
+        
+        if invert_t:
+            t = 1.0 - t
+
+        t = self.velocity_fn(t)
+
+        if m_weight is None:
+            m_weight = self.m_weight
+        else:
+            m_weight = max(0.0, min(1.0, m_weight))
+
+        if m_weight == 0:
+            _tmp_pose = self._interpolate(t, traj_fn=traj_fn, shift=0)
+        else:
+            _tmp_pose = self._align_pose_z_to_motion(lambda t: self._interpolate(t, traj_fn=traj_fn, shift=0), t, a=m_weight)
+        
+        # Apply offset
+        if self.spline_offset != 0.0:
+            # Calcola linea dal centroide alla posizione corrente
+            current_pos = _tmp_pose[:3, 3]
+            direction = current_pos - self.centroid
+            # direction = current_pos - self.centroids[math.floor(t * self.n_centroids) % self.n_centroids]
+            direction /= np.linalg.norm(direction)
+            offset_pos = current_pos + self.spline_offset * direction
+            _tmp_pose[:3, 3] = offset_pos
+            
+            # # Calcola la tangente usando differenze finite
+            # current_pos = _tmp_pose[:3, 3]
+            # dt = 1e-6
+            # eps = 1e-6
+            # tangent = np.zeros(3, dtype=np.float64)
+            # n_tangent = 0.0
+            # _dt = dt
+
+            # while n_tangent < eps and (t - _dt >= 0 or t + _dt <= 1.0):
+            #     _dt += dt
+                
+            #     # Derivata prima (centrale)
+            #     p_plus = self.pos_interp_f(min(1.0, t + _dt))
+            #     p_minus = self.pos_interp_f(max(0.0, t - _dt))
+            #     tangent = (p_plus - p_minus) / (2 * _dt)
+            #     n_tangent = np.linalg.norm(tangent)
+                
+            # # Normalizza la tangente
+            # tangent_norm = tangent / n_tangent
+            
+            # # Derivata seconde (per curvatura)
+            # dtangent = (p_plus - 2 * current_pos + p_minus) / (_dt**2)
+            
+            # # Calcola la normale nel piano XY (ruota la tangente di 90 gradi)
+            # normal = np.array([-tangent_norm[1], tangent_norm[0], 0])
+            # normal_norm = np.linalg.norm(normal)
+            # normal = normal / normal_norm
+            
+            # # Calcolo raggio di curvatura
+            # num = (tangent[0]**2 + tangent[1]**2)**1.5
+            # den = abs(tangent[0]*dtangent[1] - tangent[1]*dtangent[0])
+            # rho = np.inf if num < 1e-9 else den / num
+            # # rho = np.inf if den < 1e-9 else num / den
+            
+            # # Se offset troppo grande rispetto alla curvatura, riducilo
+            # effective_offset = np.sign(self.spline_offset) * min(abs(self.spline_offset), rho / 100000)
+            # # effective_offset = self.spline_offset
+
+            # # Applica l'offset lungo la normale
+            # offset_pos = current_pos + effective_offset * normal
+            # _tmp_pose[:3, 3] = offset_pos
+
+        final_shift = shift if shift is not None else (self.shift if self.shift is not None else 0.0)
+        return self._applyStereoPose(_tmp_pose, final_shift)
+
+    def _interpolate(self, t: float, traj_fn: Optional[Callable] = None, shift: Optional[float] = None) -> np.ndarray:
+        pos = self.pos_interp_f(t)
+        lookat = self.lookat_interp_f(t)
+        lookat = lookat / np.linalg.norm(lookat)
+        right_ = self.right_interp_f(t)
+        right_ = right_ / np.linalg.norm(right_)
+        
+        down = np.cross(lookat, right_)
+        right = np.cross(down, lookat)
+        c2w = np.eye(4, dtype=np.float64)
+        c2w[:3, 0] = right
+        c2w[:3, 1] = down
+        c2w[:3, 2] = lookat
+        c2w[:3, 3] = pos
+
+        if traj_fn is None:
+            traj_fn = self.traj_fn
+        if shift is None:
+            shift = self.shift
+
+        if traj_fn is not None and shift is not None:
+            c2w = traj_fn(c2w, t, shift=shift)
+        
+        return c2w
