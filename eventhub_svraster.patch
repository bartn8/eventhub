+@njit
+def render_events_to_canvas(canvas, x: np.ndarray, y: np.ndarray, p: np.ndarray, preview_scale_x: float = 1.0, preview_scale_y: float = 1.0):
+    """
+    Render events onto a canvas with a white background, using red for positive polarity and blue for negative polarity.
+
+    Args:
+        canvas (np.ndarray): The image canvas to render events onto. Should be a 3D NumPy array (height, width, 3) representing an RGB image.
+        x (np.ndarray): 1D array of x-coordinates for each event.
+        y (np.ndarray): 1D array of y-coordinates for each event.
+        p (np.ndarray): 1D array of polarities for each event. Positive values indicate positive polarity (rendered in red), non-positive values indicate negative polarity (rendered in blue).
+
+    Modifies:
+        canvas (np.ndarray): The input canvas is modified in-place with rendered events.
+    """
+    for i in range(x.shape[0]):
+        xi = min(max(round(x[i] / preview_scale_x), 0), canvas.shape[1] - 1)
+        yi = min(max(round(y[i] / preview_scale_y), 0), canvas.shape[0] - 1)
+        if p[i] > 0:
+            canvas[yi, xi, 0] = 0    # B
+            canvas[yi, xi, 1] = 0    # G
+            canvas[yi, xi, 2] = 255  # R
+        else:
+            canvas[yi, xi, 0] = 255  # B
+            canvas[yi, xi, 1] = 0    # G
+            canvas[yi, xi, 2] = 0    # R
+
