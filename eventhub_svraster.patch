+
+    def create_trajectory_line(poses, opacity=1.0, custom_color=None):
+        """Create a 3D line set connecting all poses (camera centers)"""
+        points = [pose[:3, 3] for pose in poses]
+        lines = [[i, i + 1] for i in range(len(points) - 1)]
+        
+        line_set = o3d.geometry.LineSet()
+        line_set.points = o3d.utility.Vector3dVector(points)
+        line_set.lines = o3d.utility.Vector2iVector(lines)
+
+        # Optional: color the line as gray or using a gradient with opacity
+        colors = color_gradient(len(lines))
+
+        if custom_color is not None:
+            colors = [custom_color for _ in colors]
+
+        opacity_colors = []
+        for c in colors:
+            opacity_colors.append([c[0] * opacity + (1 - opacity) * 1.0,
+                                   c[1] * opacity + (1 - opacity) * 1.0,
+                                   c[2] * opacity + (1 - opacity) * 1.0])
+        line_set.colors = o3d.utility.Vector3dVector(opacity_colors)
+        return line_set
+
+    def draw_sparse_poses_with_trajectory(poses, step=100, size=0.1, opacity=1.0, custom_color=None):
+        geometries = []
