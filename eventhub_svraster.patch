+        mesh_path: Path opzionale alla mesh
+        camera_idx: Indice della camera da usare
+    """
+    # 1. Carica modello e camere
+    voxel_model, cams = load_model_and_cameras(model_path)
+    
+    # 2. Seleziona una camera
+    selected_cam = cams[camera_idx]
+    cam_params = extract_camera_parameters(selected_cam)
+    
+    print(f"Using camera {camera_idx}")
+    print(f"Camera pose: {cam_params['pose']}")
+    print(f"Image size: {cam_params['width']}x{cam_params['height']}")
+    print(f"FOV: {cam_params['fovx']:.3f}, {cam_params['fovy']:.3f}")
+    
+    # 3. Renderizza con SparseVoxelModel
+    render_pkg = render_with_sparse_voxel_model(
+        pose=cam_params['pose'],
+        voxel_model=voxel_model,
+        fovx=cam_params['fovx'],
+        fovy=cam_params['fovy'],
+        width=cam_params['width'],
+        height=cam_params['height']
+    )
+    
+    # Estrai risultati
+    rgb_image = render_pkg['color']  # Shape: [3, H, W]
+    depth_image = render_pkg['depth'][[0]]  # Shape: [1, H, W]
+    
+    print(f"RGB shape: {rgb_image.shape}")
+    print(f"Depth shape: {depth_image.shape}")
+    print(f"Depth range: {depth_image.min().item():.3f} - {depth_image.max().item():.3f}")
+    
+    # 4. Converti depth in colormap magma
+    depth_colored = depth_to_colormap(depth_image, colormap='magma')
+    
+    # 5. Renderizza depth con mesh (se disponibile)
+    mesh_rgb = None
+    mesh_depth = None
+    if mesh_path and os.path.exists(mesh_path):
+        print(f"Rendering depth with mesh...")
+        pyrender_camera = create_camera_node(
+            cam_params['focal_x'], 
+            cam_params['focal_y'], 
+            cam_params['c_x'], 
+            cam_params['c_y']
+        )
+        pyrender_scene, cam_node = create_mesh_scene(mesh_path, pyrender_camera)
+        pyrender_renderer = pyrender.OffscreenRenderer(
+            viewport_width=cam_params['width'], 
+            viewport_height=cam_params['height']
+        )
+        
+        mesh_rgb, mesh_depth = render_with_mesh(
+            pyrender_scene, 
+            cam_node, 
+            pyrender_renderer, 
+            cam_params['pose']
+        )
+        
+        print(f"Mesh depth shape: {mesh_depth.shape}")
+        print(f"Mesh depth range: {mesh_depth.min():.3f} - {mesh_depth.max():.3f}")
+    
+    return {
+        'rgb_image': rgb_image,
+        'depth_image': depth_image,
+        'depth_colored': depth_colored,
+        'mesh_rgb': mesh_rgb,
+        'mesh_depth': mesh_depth,
+        'camera_params': cam_params,
+        'render_pkg': render_pkg
+    }
+
+
+if __name__ == "__main__":
+    import argparse
+
+    
+    parser = argparse.ArgumentParser(description="Estrai rendering da SparseVoxelModel")
+    parser.add_argument('model_path', help='Path al modello SparseVoxelModel')
+    parser.add_argument('--mesh_path', default=None, help='Path opzionale alla mesh')
+    parser.add_argument('--camera_idx', default=0, type=int, help='Indice della camera da usare')
+    parser.add_argument('--interactive', action='store_true', help='Modalità interattiva con slider per la mesh')
+    parser.add_argument('--viewer3d', action='store_true', help='Modalità 3D viewer interattivo per esplorare la mesh')
+    parser.add_argument('--live', action='store_true', help='Modalità live viewer con tracking in tempo reale della posa')
+    
+    args = parser.parse_args()
+    
+    if args.live:
+        # Modalità live viewer
+        print("Starting live viewer mode...")
+        live_viewer(args.model_path, args.mesh_path, args.camera_idx)
+    elif args.interactive:
+        # Modalità interattiva con slider
+        print("Starting interactive mode...")
+        interactive_example(args.model_path, args.mesh_path, args.camera_idx)
+    else:
+        # Modalità normale (statica)
+        print("Starting static mode...")
+        results = example_usage(args.model_path, args.mesh_path, args.camera_idx)
+        
+        # Converti RGB per visualizzazione
+        rgb_np = results['rgb_image'].permute(1, 2, 0).cpu().numpy()
+        rgb_np = np.clip(rgb_np, 0, 1)
+        
+        # Salva immagini
+        plt.figure(figsize=(15, 5))
+        
+        plt.subplot(1, 4, 1)
+        plt.imshow(rgb_np)
+        plt.title('RGB (SparseVoxelModel)')
+        plt.axis('off')
+        
+        plt.subplot(1, 4, 2)
+        plt.imshow(results['depth_colored'])
+        plt.title('Depth Magma (SparseVoxelModel)')
+        plt.axis('off')
+
+        if results['mesh_rgb'] is not None:        
+            plt.subplot(1, 4, 3)
+            plt.imshow(results['mesh_rgb'])
+            plt.title('RGB (Mesh)')
+            plt.axis('off')
+        
+        if results['mesh_depth'] is not None:
