+            render_img_path = render_img_path_a if os.path.exists(render_img_path_a) else render_img_path_b
+            metrics = evaluate_rendered_images(gt_img_path, gt_depth_path, render_img_path, render_depth_path, scale_depth=scale_depth)
+            metrics['image'] = base
