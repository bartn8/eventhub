+def transform_inv(T):
+    T_inv = np.eye(4)
+    T_inv[:3,:3] = T[:3,:3].T
+    T_inv[:3,3] = -1.0 * ( T_inv[:3,:3] @ T[:3,3] )
+    return T_inv
+
+def transform_inv_torch(T):
+    T_inv = torch.eye(4, device=T.device)
+    T_inv[:3,:3] = T[:3,:3].transpose(0, 1)
+    T_inv[:3,3] = -1.0 * ( T_inv[:3,:3] @ T[:3,3] )
+    return T_inv
