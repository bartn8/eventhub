+def calculateBiOpticalFlow(depth_a: np.ndarray, depth_b: np.ndarray, pose_a: np.ndarray, pose_b: np.ndarray, K: np.ndarray, c2w: bool = True, quantile: float = 0.98) -> tuple:
+    """
+    Calculate the bi-directional optical flow vectors between two depth maps, with quantile-based filtering for spurious values.
+
+    Args:
+        depth_a (np.ndarray): Depth map at time t.
+        depth_b (np.ndarray): Depth map at time t+1.
+        pose_a (np.ndarray): Camera pose at time t (4x4 matrix).
+        pose_b (np.ndarray): Camera pose at time t+1 (4x4 matrix).
+        K (np.ndarray): Camera intrinsic matrix (3x3).
+        c2w (bool): If True, poses are in camera-to-world format; if False, world-to-camera.
+        quantile (float): Quantile threshold for filtering spurious flow vectors (0-1).
+
+    Returns: 
+        F_0_1_filtered (np.ndarray): Filtered optical flow vectors from depth_a to depth_b (N x 2).
+        F_1_0_filtered (np.ndarray): Filtered optical flow vectors from depth_b to depth_a (N x 2).
+        valid_mask_0_1 (np.ndarray): Mask indicating valid pixels for flow 0->1 (H x W).
+        valid_mask_1_0 (np.ndarray): Mask indicating valid pixels for flow 1->0 (H x W).
+    """
+
+    depth_a = torch.from_numpy(depth_a).float().unsqueeze(0).unsqueeze(0) # 1 1 H W # type: ignore
+    depth_b = torch.from_numpy(depth_b).float().unsqueeze(0).unsqueeze(0) # 1 1 H W # type: ignore
+    pose_a = torch.from_numpy(pose_a).float().unsqueeze(0) # 1 4 4 # type: ignore
+    pose_b = torch.from_numpy(pose_b).float().unsqueeze(0) # 1 4 4 # type: ignore
+    K = torch.from_numpy(K).float().unsqueeze(0) # 1 3 3 # type: ignore
+
+    H, W = depth_a.shape[2], depth_a.shape[3]
+
+    # coords grid
+    coords = kornia.utils.create_meshgrid(H, W, normalized_coordinates=False).to(depth_a.device) # 1 H W 2 # type: ignore    
+    coords = coords.reshape(1, -1, 2) # 1 N 2
+
+    # Convert depth maps to 3D point clouds
+    pts_a = kornia.geometry.depth.depth_to_3d(depth_a, K).reshape(1, 3, -1).permute(0, 2, 1) # 1 3 H W to 1 3 N to 1 N 3
+    pts_b = kornia.geometry.depth.depth_to_3d(depth_b, K).reshape(1, 3, -1).permute(0, 2, 1) # 1 3 H W to 1 3 N to 1 N 3
