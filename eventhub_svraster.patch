+#!/usr/bin/env python3
+"""
+Script per convertire poses.txt e intrinsics.txt in un file transforms.json semplificato (fake).
+Rimuove o omette gli attributi non ricavabili: camera_angle_x, camera_angle_y, aabb_scale, file_path, sharpness.
+
+Utilizzo:
+    python faketransformconv.py poses.txt intrinsics.txt output_transforms.json
+"""
+import sys
+import numpy as np
+import json
+
+def load_intrinsics(path):
+    # Carica la matrice 3x3 da intrinsics.txt
+    K = np.loadtxt(path)
+    fx = K[0, 0]
+    fy = K[1, 1]
+    cx = K[0, 2]
+    cy = K[1, 2]
+    w = int(round(cx * 2))  # Stima larghezza
+    h = int(round(cy * 2))  # Stima altezza
+    return {
+        'fl_x': float(fx),
+        'fl_y': float(fy),
+        'cx': float(cx),
+        'cy': float(cy),
+        'w': w,
+        'h': h,
+        'k1': 0.0,
+        'k2': 0.0,
+        'k3': 0.0,
+        'k4': 0.0,
+        'p1': 0.0,
+        'p2': 0.0,
+        'is_fisheye': False
+    }
+
+def pose_line_to_matrix(line):
+    vals = [float(x) for x in line.strip().split()]
+    assert len(vals) == 7, f"Ogni riga di pose deve avere 7 valori, trovato: {len(vals)}"
+    tx, ty, tz, qx, qy, qz, qw = vals
+    # Costruisci matrice di rotazione da quaternion (qx, qy, qz, qw)
+    # (w, x, y, z) = (qw, qx, qy, qz)
+    x, y, z, w = qx, qy, qz, qw
+    R = quaternion_to_rotation_matrix(x, y, z, w)
+    T = np.eye(4)
+    T[:3, :3] = R
+    T[:3, 3] = [tx, ty, tz]
+    return T.tolist()
+
+def quaternion_to_rotation_matrix(x, y, z, w):
+    # Quaternion normalizzato
+    n = x*x + y*y + z*z + w*w
+    if n < 1e-8:
+        return np.eye(3)
+    s = 2.0 / n
+    wx, wy, wz = w*x, w*y, w*z
+    xx, xy, xz = x*x, x*y, x*z
+    yy, yz, zz = y*y, y*z, z*z
+    return np.array([
+        [1-s*(yy+zz),   s*(xy-wz),     s*(xz+wy)],
+        [s*(xy+wz),     1-s*(xx+zz),   s*(yz-wx)],
+        [s*(xz-wy),     s*(yz+wx),     1-s*(xx+yy)]
+    ])
+
+def main():
+    if len(sys.argv) != 2:
+        print("Uso: python faketransformconv.py <cartella>")
+        sys.exit(1)
+    folder = sys.argv[1]
+    poses_path = f"{folder}/poses.txt"
+    intr_path = f"{folder}/intrinsics.txt"
+    out_path = f"{folder}/transforms.json"
+    intr = load_intrinsics(intr_path)
+    with open(poses_path) as f:
+        pose_lines = [l for l in f if l.strip() and not l.strip().startswith('#')]
+    frames = []
+    for i, line in enumerate(pose_lines):
+        T = pose_line_to_matrix(line)
+        frames.append({
+            'transform_matrix': T
+        })
+    out = {**intr, 'frames': frames}
+    with open(out_path, 'w') as f:
+        json.dump(out, f, indent=4)
+    print(f"Scritto: {out_path} ({len(frames)} pose)")
+
+if __name__ == '__main__':
+    main()
