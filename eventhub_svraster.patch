+import os
+import time
+import numpy as np
+from tqdm import tqdm
+from os import makedirs
+import imageio
+import cv2
+import math
+import json
+import h5py
+import pandas as pd
+import glob
+import torch
+import torch.nn as nn
+import torch.nn.functional as F
+from kornia.filters import median_blur
+
+from src.config import cfg, update_argparser, update_config
+
+from src.dataloader.data_pack import DataPack
+from src.sparse_voxel_model import SparseVoxelModel
+from src.cameras import MiniCam
+from src.utils.loss_utils import psnr_score, ssim_score
+
+def min_pooling(x, kernel_size=3, stride=1, padding=1):
+    return -F.max_pool2d(-x, kernel_size=kernel_size, stride=stride, padding=padding)
+
+def rms_linear(y_input, y_target):
+    mask = (y_input > 0) & (y_target > 0) & (~np.isnan(y_target))
+    y_input = y_input[mask]
+    y_target = y_target[mask]
+    abs_diff = np.abs(y_target-y_input)
+    return np.sqrt((abs_diff**2).mean())
+
+def mean_error(y_input, y_target):
+    mask = (y_input > 0) & (y_target > 0) & (~np.isnan(y_target))
+    y_input = y_input[mask]
+    y_target = y_target[mask]
+    abs_diff = np.abs(y_target-y_input)
+    return abs_diff.mean()
+
+def th_delta_error(y_input, y_target, th=1.25):
+    eps = 1e-5
+    mask = (y_input > 0) & (y_target > 0) & (~np.isnan(y_target))
+    y_input = y_input[mask]
+    y_target = y_target[mask]
+    ratio = np.max(np.stack([y_target/(y_input+eps),y_input/(y_target+eps)]), axis=0)
+    return np.mean(ratio <= th)
+
+if __name__ == "__main__":
+    # Parse arguments
+    import argparse
+    parser = argparse.ArgumentParser(
+        description="Depth Ablation Evaluation.")
+
+    parser.add_argument('ablation_path', type=str, help='Path to the ablation directory.')
+    parser.add_argument('dataset_path', type=str, help='Path to the dataset directory (to get depth data).')
+
+    parser.add_argument("--iteration", default=-1, type=int)
+    parser.add_argument("--render_scale", default=1.0, type=float)
+
+    # parser.add_argument("--ao_th", default=0.0, type=float, help="AO threshold for confidence filtering.")
+    # parser.add_argument("--ao_size_th", default=0.0, type=float, help="AO size threshold for confidence filtering.")
+    parser.add_argument("--th", default=0.0, type=float, help="Threshold for confidence filtering.")
+
+    parser.add_argument('--hashes', nargs='+', default=[],
+                        help='List of hashes to process. If empty, all hashes will be processed.')
+
+    args = parser.parse_args()
+
+    # Get the list of experiments
+    csv_file = os.path.join(args.ablation_path, 'parameters.csv')
+    new_csv_file = os.path.join(args.ablation_path, 'evaluation.csv')
+    df = pd.read_csv(csv_file)
+    df = df.drop_duplicates(subset=['hash'])
+    
+    # Add result columns
+    result_columns = [
+        'psnr', 'ssim',
+        'mae', 'rmse', 'th1', 'th2', 'th3',
+        'mae_alpha', 'rmse_alpha', 'th1_alpha', 'th2_alpha', 'th3_alpha',
+        'mae_ao', 'rmse_ao', 'th1_ao', 'th2_ao', 'th3_ao',
+        'mae_size', 'rmse_size', 'th1_size', 'th2_size', 'th3_size',
+        'mae_alpha_ao', 'rmse_alpha_ao', 'th1_alpha_ao', 'th2_alpha_ao', 'th3_alpha_ao',
+        'mae_alpha_size', 'rmse_alpha_size', 'th1_alpha_size', 'th2_alpha_size', 'th3_alpha_size',
+        'mae_ao_size', 'rmse_ao_size', 'th1_ao_size', 'th2_ao_size', 'th3_ao_size',
+        'mae_ao_size_alpha', 'rmse_ao_size_alpha', 'th1_ao_size_alpha', 'th2_ao_size_alpha', 'th3_ao_size_alpha',
+        'mae_ao2_size_alpha', 'rmse_ao2_size_alpha', 'th1_ao2_size_alpha', 'th2_ao2_size_alpha', 'th3_ao2_size_alpha',
+        'ao_sparsity', 'size_sparsity', 'ao_size_sparsity', 'alpha_sparsity', 'alpha_size_sparsity', 'alpha_ao_sparsity', 'ao_size_alpha_sparsity', 'ao2_size_alpha_sparsity', 'ao2_sparsity',
+        'inv_mae', 'inv_mae_alpha', 'inv_mae_size', 'inv_mae_ao', 'inv_mae_alpha_ao', 'inv_mae_alpha_size', 'inv_mae_ao_size', 'inv_mae_ao_size_alpha', 'inv_mae_ao2_size_alpha'
+    ]
+
+    for col in result_columns:
+        if col not in df.columns:
+            df[col] = np.nan
+
+    # Iterate over hash values
+    hashes = df['hash'].unique()
+    if len(args.hashes) > 0:
+        # print(f"Available hashes: {hashes}")
+        # print(f"Filtering experiments to only include hashes: {args.hashes}")
+        hashes = [h for h in hashes if h in args.hashes]
+        if len(hashes) == 0:
+            raise ValueError("No valid hashes found in the provided list.")
+        else:
+            print(f"Processing only the following hashes: {hashes}")
+            df = df[df['hash'].isin(hashes)]
+        
+        
+    pbar = tqdm(hashes, desc="Processing Experiments")
+    for hash_value in pbar:
+        experiments_scenes = glob.glob(os.path.join(args.ablation_path, hash_value, '*', "checkpoints", "iter020000_model.pt"))
+
+        if len(experiments_scenes) != 15:
+            print(f"Warning! Hash {hash_value} has {len(experiments_scenes)} experiments instead of 15.")
+            
+
+        # Create aggregator for results
+        results = {
+            key: [] for key in result_columns
+        }
+
+        for experiment_path in experiments_scenes:
+            scene_path = os.path.abspath(os.path.join(os.path.dirname(experiment_path), '..'))
+            scene_id = os.path.basename(scene_path)
+
+            pbar.set_description(f"Experiment: {hash_value}; Scene {scene_id}")
+
+            # Load config
+            update_config(os.path.join(scene_path, 'config.yaml'))
+            res_downscale = cfg.data.res_downscale
+            source_path = cfg.data.source_path
+            
+            # Load data
+            data_pack = DataPack(cfg.data, cfg.model.white_background, camera_params_only=False)
+
+            # Load cameras
+            cams = data_pack.get_train_cameras()
+
+            # Recover depth data
+            depth_path = os.path.join(args.dataset_path, scene_id, 'depths')
+            depths = sorted(glob.glob(os.path.join(depth_path, '*.png')))
+            depths_dict = {os.path.splitext(os.path.basename(depth))[0]: depth for depth in depths}
+            depths = [depths_dict[cams[i].image_name.split(".")[0]] for i in range(len(cams))]
+            poses = [cams[i].c2w.cpu().numpy() for i in range(len(cams))] 
+            
+            # Load model
+            voxel_model = SparseVoxelModel(cfg.model)
+            loaded_iter = voxel_model.load_iteration(args.iteration)
+            voxel_model.freeze_vox_geo()
+
+            # Rendering
+            fovx = cams[0].fovx
+            fovy = cams[0].fovy
+            width = round(cams[0].image_width / args.render_scale)
+            height = round(cams[0].image_height / args.render_scale)
+            focal = width / (2 * np.tan(fovx / 2))
+
+            # Using the focal from COLMAP gives a marginal better result
+            # However, it is more difficult to handle different FOVs.
+            # Plus, it has to be retrieved from the COLMAP database
+            # Possible TODO: use a scale n shift optimization to match the focal
+
+
+            for i in range(len(cams)):
+                pose = poses[i]
+                image = cams[i].image # 3 H W
+                # Scannet++ depth maps are 16-bit PNGs (mm unit)
+                depth = cv2.imread(depths[i], cv2.IMREAD_ANYDEPTH) / 1000.0 # Convert to meters
+                # Need this if res_downscale is not 1.0
+                depth = cv2.resize(depth, (width, height), interpolation=cv2.INTER_NEAREST)
+                
+                depth_multiplier = 1000
+                eps = 1e-5
+                inv_depth = depth_multiplier / (depth + eps)
+                
+                                
+                cam = MiniCam(
+                    c2w=pose,
+                    fovx=fovx, fovy=fovy,
+                    width=width, height=height)
+
+                with torch.no_grad():
+                    render_pkg = voxel_model.render(cam, output_depth=True, output_T=True)
+                    #dict_keys(['color', 'depth', 'normal', 'T', 'max_w', 'feat', 'sizeconf', 'ao', 'raw_color', 'raw_depth', 'raw_normal', 'raw_T', 'raw_feat'])
+
+                    rendering_color = render_pkg['color'] # 3 H W
+                    
+                    rendering_depth = render_pkg['depth'][[0]] # 1 H W
+                    rendering_depth_median = render_pkg['depth'][[2]] # 1 H W
+
+                    rendering_alpha = render_pkg["T"] # 1 H W
+                    rendering_alpha = rendering_alpha / rendering_alpha.max() # Normalize alpha to [0, 1]
+                    rendering_alpha = 1-rendering_alpha # Invert alpha to match the AO
+                    
+                    rendering_ao = render_pkg['ao'] # 1 H W
+                    rendering_ao = rendering_ao / rendering_ao.max()
+                    inv_rendering_ao = 1-rendering_ao
+
+                    rendering_sizeconf = render_pkg['sizeconf'] # 1 H W
+                    rendering_sizeconf = rendering_sizeconf / rendering_sizeconf.max()
+                    rendering_sizeconf = 1 - rendering_sizeconf # Invert the size confidence to match the AO
+
+                #Evaluate PSNR and SSIM
+                psnr = psnr_score(rendering_color.cuda(), image.cuda()).cpu().squeeze().numpy()
+                ssim = ssim_score(rendering_color.cuda(), image.cuda()).cpu().squeeze().numpy()
+
+                #Evaluate depth (Without confidence)
+                rendering_depth = rendering_depth.squeeze().cpu().numpy()
+                mae = mean_error(rendering_depth, depth)
+                inv_mae = mean_error(depth_multiplier / (rendering_depth + eps), inv_depth)
+                rmse = rms_linear(rendering_depth, depth)
+                th1 = th_delta_error(rendering_depth, depth, th=1.25)
+                th2 = th_delta_error(rendering_depth, depth, th=1.25**2)
+                th3 = th_delta_error(rendering_depth, depth, th=1.25**3)
+
+                #Evaluate depth (with Alpha confidence)
+                alpha_confidence = (rendering_alpha > args.th).squeeze().cpu().numpy().astype(np.float32)
+                alpha_sparsity = alpha_confidence.mean()
+                rendering_depth_alpha = rendering_depth * alpha_confidence
+                mae_alpha = mean_error(rendering_depth_alpha, depth)
+                inv_mae_alpha = mean_error(depth_multiplier / (rendering_depth_alpha + eps), inv_depth)
+                rmse_alpha = rms_linear(rendering_depth_alpha, depth)
+                th1_alpha = th_delta_error(rendering_depth_alpha, depth, th=1.25)
+                th2_alpha = th_delta_error(rendering_depth_alpha, depth, th=1.25**2)
+                th3_alpha = th_delta_error(rendering_depth_alpha, depth, th=1.25**3)
+
+                #Evaluate depth (with AO confidence)
+                ao_confidence = (rendering_ao > args.th).squeeze().cpu().numpy().astype(np.float32)
+                ao_sparsity = ao_confidence.mean()
+                rendering_depth_ao = rendering_depth * ao_confidence
+                mae_ao = mean_error(rendering_depth_ao, depth)
+                inv_mae_ao = mean_error(depth_multiplier / (rendering_depth_ao + eps), inv_depth)
+                rmse_ao = rms_linear(rendering_depth_ao, depth) 
+                th1_ao = th_delta_error(rendering_depth_ao, depth, th=1.25)
+                th2_ao = th_delta_error(rendering_depth_ao, depth, th=1.25**2)
+                th3_ao = th_delta_error(rendering_depth_ao, depth, th=1.25**3)
+                
+                # Evaluate depth (with size confidence)
+                size_confidence = (rendering_sizeconf > args.th).squeeze().cpu().numpy().astype(np.float32)
+                size_sparsity = size_confidence.mean()
+                rendering_depth_size = rendering_depth * size_confidence
+                mae_size = mean_error(rendering_depth_size, depth)
+                inv_mae_size = mean_error(depth_multiplier / (rendering_depth_size + eps), inv_depth)
+                rmse_size = rms_linear(rendering_depth_size, depth)
+                th1_size = th_delta_error(rendering_depth_size, depth, th=1.25)
+                th2_size = th_delta_error(rendering_depth_size, depth, th=1.25**2)
+                th3_size = th_delta_error(rendering_depth_size, depth, th=1.25**3)
+                
+                #Evaluate depth (with alpha and ao confidence)
+                alpha_ao_confidence = rendering_alpha * rendering_ao
+                alpha_ao_confidence = (alpha_ao_confidence > args.th).squeeze().cpu().numpy().astype(np.float32)
+                alpha_ao_sparsity = alpha_ao_confidence.mean()
+                rendering_depth_alpha_ao = rendering_depth * alpha_ao_confidence
