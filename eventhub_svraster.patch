+def live_viewer(model_path, mesh_path=None, camera_idx=0):
+    """
+    Visualizzatore live con feedback in tempo reale della posa della camera
+    
+    Args:
+        model_path: Path al modello SparseVoxelModel
+        mesh_path: Path alla mesh
+        camera_idx: Indice della camera da usare
+    """
+    if not mesh_path or not os.path.exists(mesh_path):
+        print("Mesh path required for live viewer mode!")
+        return
+    
+    print("Loading model and cameras...")
+    # 1. Carica modello e camere
+    voxel_model, cams = load_model_and_cameras(model_path)
+    
+    # 2. Seleziona una camera
+    selected_cam = cams[camera_idx]
+    cam_params = extract_camera_parameters(selected_cam)
+    
+    # Print translation (TX, TY, TZ) and rotation (RX, RY, RZ) in degrees
+    tx, ty, tz = cam_params['pose'][:3, 3]
+    # Extract rotation matrix
+    R = cam_params['pose'][:3, :3]
+    # Convert rotation matrix to Euler angles (rx, ry, rz)
+    euler = cv2.Rodrigues(R)[0].flatten()
+    rx, ry, rz = euler
+    rx, ry, rz = np.degrees([rx, ry, rz])
+    print(f"TX: {tx:.4f}, TY: {ty:.4f}, TZ: {tz:.4f}")
+    print(f"RX: {rx:.2f}°, RY: {ry:.2f}°, RZ: {rz:.2f}°")
+    
+    # Aggiungi l'indice della camera ai parametri per la stampa
+    cam_params['camera_idx'] = camera_idx
+    
+    print(f"Setting up live viewer...")
+    
+    # 3. Crea la scena pyrender
+    view_cam = create_camera_node(
+        cam_params['focal_x'], 
+        cam_params['focal_y'], 
+        cam_params['c_x'], 
+        cam_params['c_y']
+    )
+    scene, cam_node = create_mesh_scene(mesh_path, view_cam)        
+    
+    # 6. Start viewer in another thread
+    print("\n" + "="*60)
+    print("🔴 LIVE VIEWER MODE")
+    print("="*60)
+    print("🎮 CONTROLS:")
+    print("- Mouse Left: Rotate camera")
+    print("- Mouse Right: Pan camera") 
+    print("- Mouse Wheel: Zoom")
+    print("- W/A/S/D: Move camera")
+    print("="*60)
+    print("🔄 LIVE POSE TRACKING:")
+    print("Move the camera in the viewer. Press Ctrl-C here to stop.")
+    print("="*60 + "\n")
+
+    viewer = pyrender.Viewer(scene, viewport_size=(cam_params['width'], cam_params['height']), use_raymond_lighting=True, run_in_thread=True, viewer_flags={'show_world_axis': True, 'show_mesh_axes': True})
+
+    try:
+        while True:
+            # Camera-to-world (used internally by pyrender)
+            c2w = viewer._trackball.pose.copy()
+
+            # World-to-camera (inverse)
+            w2c = np.linalg.inv(c2w)
+
+            # Extract position and rotation from c2w
+            tx, ty, tz = c2w[:3, 3]
+            R = c2w[:3, :3]
+            euler = cv2.Rodrigues(R)[0].flatten()
+            rx, ry, rz = euler
+
+            # Print live pose information
+            print(f"🎯 LIVE CAMERA2WORLD POSE:")
+            print(f"   Position: TX={tx:+8.4f}, TY={ty:+8.4f}, TZ={tz:+8.4f}")
+            print(f"   Rotation: RX={np.degrees(rx):+8.2f}°, RY={np.degrees(ry):+8.2f}°, RZ={np.degrees(rz):+8.2f}°")
+            print("-" * 60)
+            
+            tx, ty, tz = w2c[:3, 3]
+            R = w2c[:3, :3]
+            euler = cv2.Rodrigues(R)[0].flatten()
+            rx, ry, rz = euler
+            print(f"🎯 LIVE WORLD2CAMERA POSE:")
+            print(f"   Position: TX={tx:+8.4f}, TY={ty:+8.4f}, TZ={tz:+8.4f}")
+            print(f"   Rotation: RX={np.degrees(rx):+8.2f}°, RY={np.degrees(ry):+8.2f}°, RZ={np.degrees(rz):+8.2f}°")
+            print("-" * 60)
+            
+
+            time.sleep(5.0)
+
+    except KeyboardInterrupt:
+        print("\n" + "="*60)
+        print("✅ Live viewer stopped successfully!")
+        print("="*60)
+
