+        pose_b_a = kornia.geometry.linalg.compose_transformations(kornia.geometry.linalg.inverse_transformation(pose_b), pose_a) # 1 4 4 # type: ignore
+        pose_a_b = kornia.geometry.linalg.compose_transformations(kornia.geometry.linalg.inverse_transformation(pose_a), pose_b) # 1 4 4 # type: ignore
+    else: 
