+    parser.add_argument("--height", default=None, type=int, help='Height of the rendered image. If None, it will be set to the height of the original images.')
+    parser.add_argument("--fix_aspect_ratio", action='store_true', help='Fix the aspect ratio of the rendered image. If not set, the aspect ratio will be determined by the original images.')
+    parser.add_argument("--super_sampling", default=1.5, type=float, help='Super sampling factor for rendering. Default: 1.5.')
+
+    # Rendering parameters: Extrinsics (stereo)
+    parser.add_argument('--baselines', nargs='+', default=[0.1, 0.3, 0.5], type=float, help='List of baselines to use for rendering. Default: [0.1, 0.3, 0.5].')
+    
+    #ESIM parameters
+    parser.add_argument('--contrast_threshold_neg', default=0.2, type=float)
+    parser.add_argument('--contrast_threshold_pos', default=0.2, type=float)
+    parser.add_argument('--rnd_contrast_thresholds', action='store_true', help='If set, random contrast thresholds will be used.')
+    parser.add_argument('--refractory_us', default=1000, type=int, help= 'Refractory period of the simulated event camera in microseconds. Default: 1000 us.')
+    parser.add_argument('--min_events_per_frame', default=100000, type=int, help='Minimum number of events to process per frame. If not achieved, we skip the frame. Default: 100000.')
+    parser.add_argument('--max_events_per_frame', default=500000, type=int, help='Maximum number of events to process per frame. Default: 500000.')
+    parser.add_argument("--gauss_blur_kernel", default=3, type=int, help='Gaussian blur kernel size for anti-flickering. Default: 3. Must be odd.')
+    parser.add_argument('--gauss_noise_std', default=0.0, type=float, help='Standard deviation of Gaussian noise added to the rendered images. Default: 0.0 (no noise).')
+    parser.add_argument('--rnd_gain_min', default=1.0, type=float, help='Minimum gain applied to the rendered images before event generation. Default: 1.0.')
+    parser.add_argument('--rnd_invert_gain', action='store_true', help='If set, the gain will be randomly inverted (negative) for each rendered pose.')
+    parser.add_argument('--rnd_offset_max', default=0.0, type=float, help='Maximum random offset applied to the rendered images before event generation. Default: 0.0.')
+    parser.add_argument('--num_noise_events', default=0, type=int, help='Number of random noise events to add per frame. Default: 0.')
+    parser.add_argument('--min_dt_perc', default=0.0, type=float, help='Minimum delta time percentage between two consecutive poses. Default: 0.0. Must be in [0.0, 1.0].')
+    parser.add_argument('--max_dt_perc', default=1.0, type=float, help='Maximum delta time percentage between two consecutive poses. Default: 1.0. Must be in [0.0, 1.0].')
+
+    # Manually select which frames to interpolate
+    parser.add_argument("--ids", default=[], type=int, nargs='*')
+    parser.add_argument('--max_poses', default=0, type=int, help='Maximum number of poses to render. If 0, all poses are rendered.')
+    parser.add_argument('--velocity_fn', nargs='+', default=['linear'], type=str, help='Type of velocity function to use for trajectory interpolation. Default: linear. Supported types: linear, cos2 [freq_hz > 0], gamma [gamma in (0, inf)].')
+    parser.add_argument("--duration", default=1.0, type=float, help='Duration of the rendered video in seconds. Default: 1.0.')
+    parser.add_argument("--initial_num_bisections", default=10, type=int, help='Initial number of bisections for the trajectory. Default: 5 (2^5).')
+
+    # Randomization parameters
+    parser.add_argument('--rnd_baseline', action='store_true', help='If set, a random baseline will be used for each pose.')
+    parser.add_argument('--rnd_baseline_std', default=0.01, type=float, help='Standard deviation for random baseline selection. Default: 0.01.')
+    parser.add_argument('--rnd_poses', action='store_true', help='If set, random poses will be selected from the dataset. If not set, all poses will be rendered.')
+    parser.add_argument('--rnd_invert_t', action='store_true', help='If set, the trajectory will be inverted with a 0.5p chance.')
+    parser.add_argument('--seed', default=-1, type=int, help='Random seed for reproducibility.')
+
+    args = parser.parse_args()
+
+    assert args.render_choices_left is not None, "Please specify at least one LEFT render choice."
+    assert all(choice in OUTPUT_SET for choice in args.render_choices_left), f"Invalid render choices LEFT. Available options: {', '.join(OUTPUT_SET)}."
+    assert args.render_choices_center is not None, "Please specify at least one CENTER render choice."
+    assert all(choice in OUTPUT_SET for choice in args.render_choices_center), f"Invalid render choices CENTER. Available options: {', '.join(OUTPUT_SET)}."
+    assert args.render_choices_right is not None, "Please specify at least one RIGHT render choice."
+    assert all(choice in OUTPUT_SET for choice in args.render_choices_right), f"Invalid render choices RIGHT. Available options: {', '.join(OUTPUT_SET)}."
+    assert args.focal_scale > 0, "Focal scale must be greater than 0."
+    assert isinstance(args.baselines, list) and all(isinstance(b, float) for b in args.baselines), "Baselines must be a list of floats."
+    assert all(choice != "events" for choice in args.render_choices_left), "Legacy event rendering is not supported: use eventsv2 instead."
+    assert all(choice != "events" for choice in args.render_choices_center), "Legacy event rendering is not supported: use eventsv2 instead."
+    assert all(choice != "events" for choice in args.render_choices_right), "Legacy event rendering is not supported: use eventsv2 instead."
+    assert args.min_dt_perc >= 0.0 and args.min_dt_perc <= 1.0, "min_dt_perc must be in [0.0, 1.0]."
+    assert args.max_dt_perc >= 0.0 and args.max_dt_perc <= 1.0, "max_dt_perc must be in [0.0, 1.0]."
+    assert args.min_dt_perc <= args.max_dt_perc, "min_dt_perc must be less than or equal to max_dt_perc."
+    assert args.contrast_threshold_neg > 0.0, "Contrast threshold negative must be greater than 0."
+    assert args.contrast_threshold_pos > 0.0, "Contrast threshold positive must be greater than 0."
+    assert args.max_events_per_frame > args.min_events_per_frame and args.min_events_per_frame > 0 and args.max_events_per_frame > 0, "Max events per frame must be greater than min events per frame."
+    #assert args.max_events_per_frame > 0, "Max events per frame must be greater than 0."
+    # TODO: continue asserts
+
+    #ATTENTION: You must set the seed to a positive value for same pose but different shift.
+    seed = args.seed if args.seed > 0 else int(time.time())
+    
+    if args.seed <= 0:
+        print(f"Using time seed: {seed}")
+
+    random.seed(seed)
+    np.random.seed(seed)
+    torch.manual_seed(seed)
+    torch.cuda.manual_seed_all(seed)
+
+    print("Rendering " + args.model_path)
+
+    # Load model config
+    update_config(os.path.join(args.model_path, 'config.yaml'))
+    res_downscale = cfg.data.res_downscale
+    source_path = cfg.data.source_path
+
+    # Load model data
+    data_pack = DataPack(cfg.data, cfg.model.white_background, camera_params_only=True)
+    cams = data_pack.get_train_cameras()
