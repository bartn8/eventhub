+    update_config(config_path)
+    
+    # Carica le camere
+    data_pack = DataPack(cfg.data, cfg.model.white_background, camera_params_only=True)
+    cams = data_pack.get_train_cameras()
+    
+    # Estrai le pose (matrici 4x4)
+    poses = np.stack([cams[i].c2w.cpu().numpy() for i in range(len(cams))], axis=0)  # (N, 4, 4)
+    
+    # Salva su file .npy
+    np.save(output_path, poses)
+    print(f"Salvate {poses.shape[0]} pose in {output_path}")
+
+if __name__ == "__main__":
+    parser = argparse.ArgumentParser(description="Estrai le pose delle camere e salvale in un file .npy")
+    parser.add_argument("dataset_path", nargs='+', type=str, help="Percorso delle cartelle del dataset")
+    args = parser.parse_args()
+    for dataset_path in args.dataset_path:
+        print(f"Processing dataset at: {dataset_path}")
+        main(dataset_path)
