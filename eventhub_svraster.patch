+def generateMyRenderTrajectory(key_pose, traj_configs, n_frames, n_frames_p, z_scale, rnd_freq, scene_depth, stereo_shift=0.0):
+    if isinstance(traj_configs, str):
+        # assume a path to a JSON file
+        with open(traj_configs, 'r') as f:
+            traj_configs = json.load(f) # List of dictionaries
+
+    # Generate trajectory
+    interp_poses = []
+    xyz_ref = None
+
+    for traj_config in traj_configs:
+        for key in traj_config:
+            traj_args = traj_config[key]
+            traj_args['n_frames'] = n_frames
+            traj_args['n_frames_p'] = n_frames_p
+
+            # Default lookat effect
+            lookat_fn = lambda **x: lookAtEffectWrapper(nullLookAtEffect, x, {"interpolate_start": False,
+                "interpolate_end": False, "n_frames_p": n_frames_p, "inverse": False, "stereo_shift": stereo_shift, "lookat_z": scene_depth})
+
+            # Check if the key 'relative_offset' is in the trajectory arguments
+            if 'relative_offset' in traj_args and traj_args['relative_offset']:
+                # If it is, calculate the absolute z_offset based on the median depth
+                offset = traj_args.get('offset', [0.0, 0.0, 0.0])
+                offset = np.array(offset, dtype=np.float32)                    
+                traj_args['offset'] = scene_depth * offset * z_scale
+
+                # Repeat for z_init
+                init = traj_args.get('init', [0.0, 0.0, 0.0])
+                init = np.array(init, dtype=np.float32)
+                traj_args['init'] = scene_depth * init * z_scale
+
+            if 'freq_hz' in traj_args and rnd_freq:
+                freq_hz_mul = np.random.uniform(0.0, 1.0, size=(3,))
+                traj_args['freq_hz'] = freq_hz_mul * traj_args['freq_hz']
+                
+                # Disable this function: could cause inconsistent results
