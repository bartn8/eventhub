+def calculateBiOpticalFlowMagnitude(depth_a: np.ndarray, depth_b: np.ndarray, pose_a: np.ndarray, pose_b: np.ndarray, K: np.ndarray, c2w: bool = True, quantile: float = 0.98, max_flow = 700, default_num_bisections = 5) -> tuple:
+    """
+    Calculate the bi-optical flow magnitude between two depth maps given their poses and camera intrinsics.
+
+    Args:
+        depth_a (np.ndarray): Depth map at time t.
