+        # Add camera frustums every `step` poses
+        sampled_indices = list(range(0, len(poses), step))
+        sampled_colors = color_gradient(len(sampled_indices)) if custom_color is None else [custom_color for _ in sampled_indices]
+
+        for idx, color in zip(sampled_indices, sampled_colors):
+            frustum = create_colored_frustum(poses[idx], size=size, color=color, opacity=opacity)
+            geometries.append(frustum)
+
+        return geometries
+
+    with open("configs/param_traj/h.json", "r") as f:
