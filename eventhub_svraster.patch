+                #     traj_args['lookat']['args']['freq_hz'] = freq_hz_mul * traj_args['lookat']['args']['freq_hz']
+
+
+            if 'lookat' in traj_args:
+                # Convert lookat using the dict
+                assert traj_args['lookat']['type'] in LOOKAT_EFFECT_DICT, f"Invalid lookat effect type: {traj_args['lookat']['type']}. Available options: {', '.join(LOOKAT_EFFECT_DICT.keys())}."
+                traj_args['lookat']['args'] = traj_args['lookat'].get('args', {})
+
+                traj_args['lookat']['args']['stereo_shift'] = stereo_shift
+                traj_args['lookat']['args']['lookat_z'] = scene_depth
+                traj_args['lookat']['args']['n_frames_p'] = n_frames_p
+                lookat_fn = lambda **x: lookAtEffectWrapper(LOOKAT_EFFECT_DICT[traj_args['lookat']['type']], x, traj_args['lookat']['args'])
+
+            # Generate trajectory
+            if key in TRAJ_DICT:
+                # remove relative_offset before generating the trajectory
+                _traj_args = {k: v for k, v in traj_args.items() if k not in ['relative_offset', 'lookat']}
+                _tmp_poses, xyz_ref = TRAJ_DICT[key](key_pose, xyz_ref, lookat_fn, **_traj_args)
+                interp_poses += _tmp_poses
+    
+    return interp_poses, xyz_ref
