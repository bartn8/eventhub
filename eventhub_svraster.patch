+TRAJ_DICT = {
+    'spiral': generateSpiralTrajectory,
+    'cross': generateCrossTrajectory,
+    'circle': generateCircleTrajectory,
+    'linear': generateLinearTrajectory,
+    'null': generateNullTrajectory, 
+    'repeated_random_linear': generateRepeatedRandomLinearTrajectory,
+    'cosine': generateCosineTrajectory,
