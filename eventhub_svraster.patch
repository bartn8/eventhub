+def im_tensor2np(x, mul=255):
+    if x.shape[0] == 1:
+        x = x.squeeze(0)
+    if len(x.shape) == 3:
+        x = x.moveaxis(0, -1)
+    return x.mul(mul).clamp(0,255).cpu().numpy().astype(np.uint8)
+
+def im_tensor2np16bit(x, mul=65535):
+    if x.shape[0] == 1:
+        x = x.squeeze(0)
+    if len(x.shape) == 3:
+        x = x.moveaxis(0, -1)
+    return x.mul(mul).clamp(0,65535).cpu().numpy().astype(np.uint16)
